      return 1;
    }
  }
  if (strncmp(scrCommand,"DISABLE_STEER",strlen(scrCommand))==0) {//舵角無効 251209 ikami
    if (strncmp(scrParam1,"DIS",strlen(scrParam1))==0) { // 
      setSignal(G5M::DDM_5::EPS1S11::PANGINV,1);
      return 1;
    }  else if (strncmp(scrParam1,"ENA",strlen(scrParam1))==0) {
      setSignal(G5M::DDM_5::EPS1S11::PANGINV,0);
      return 1;
    }
  }
  
  //-------------------1217追記分ここまで----------------------------------------------------------

// AVNS1S20途絶
  if (strncmp(scrCommand,"TOZETSU",strlen(scrCommand))==0) {//AVNS1S20途絶 OFFで通信途絶
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) { // 
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S20::TIMINGS::EnableCyclic,0);
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S71::TIMINGS::EnableCyclic,0);      

      return 1;
    } 
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S20::TIMINGS::EnableCyclic,1);
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S71::TIMINGS::EnableCyclic,1); 
      return 1;
    } 
  }
// 音声認識カメラON/OFF
  
  if (strncmp(scrCommand,"ONNINCAMERA",strlen(scrCommand))==0) {//AVN1S78 先進安全音認用機能
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) { // 機能ID 0x18
      setSignal(G5M::CDC_5::AVN1S78::DS_INST1,1);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST2,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST3,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST4,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST5,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_FUNID,0x18);

      cancelTimer(msExecInterval);
      alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
      setTimer(msOnNinCameraTimer,1000);
      alive_msOnNinCameraTimer = 1;
      return 0; //コマンド待ちを止める。
    } 
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 機能ID 0x17
      setSignal(G5M::CDC_5::AVN1S78::DS_INST1,1);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST2,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST3,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST4,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_INST5,0);
      setSignal(G5M::CDC_5::AVN1S78::DS_FUNID,0x17);
      cancelTimer(msExecInterval);
      alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
      setTimer(msOnNinCameraTimer,1000);
      alive_msOnNinCameraTimer = 1;
      return 0; //コマンド待ちを止める。
    } 
  }
  
  if (strncmp(scrCommand,"ONNINMARK",strlen(scrCommand))==0) {//ikami
#if 0    
    int param;
    if (strlen(scrParam1)!=0) {
      param = (int)scrParam1[0] - 0x30;
      write("%x %x", scrParam1[0], param);
      if ((param >= 0) && (param <= 5)) { 
        putValue(SigDt_AVN1S73_VR_STATE,param);
      }
    }
    return 1;
#endif
    write("scrParam1:>%s<",scrParam1);
    write("strlen(scrParam1): %d",strlen(scrParam1));
    write("0と等しい？　%d",strncmp(scrParam1,"0",strlen(scrParam1)));
    if (strlen(scrParam1)>0) {
      if (strncmp(scrParam1,"0",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,0);
        write("VR_STATE 0");
        return 1;
      }  else if (strncmp(scrParam1,"1",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,1);
        write("VR_STATE 1");
        return 1;
      }  else if (strncmp(scrParam1,"2",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,2);
        write("VR_STATE 2");
        return 1;
      }  else if (strncmp(scrParam1,"3",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,3);
        write("VR_STATE 3");
        return 1;
      }  else if (strncmp(scrParam1,"4",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,4);
        write("VR_STATE 4");
        return 1;
      }  else if (strncmp(scrParam1,"5",strlen(scrParam1))==0) { // 
        putValue(SigDt_AVN1S73_VR_STATE,5);
        write("VR_STATE 5");
        return 1;
      }
    }
    write("VR_STATE 不正　：パラメータなし");
    return 1;  // 実行を止めないために1を返しておく
  }

  ///// 工場軸調 ターゲットマーカー位置設定 TarGeTMarkerPOSition
  if (strncmp(scrCommand,"TGTMKRPOS",strlen(scrCommand))==0) {
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    FactoryAdjustStep = 0;
    FactoryAdjust();
    return 0;
  }

  //// カメラソフトＳＷ
  if (strncmp(scrCommand,"SW_PVM",strlen(scrCommand))==0) {
    write("SW_PVM");
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    SoftCameraSW_Script();
    return 0;
  }
  
  //// SID22 ダイアグ1483送信  光軸調整状態の確認（ビューデータ生成が完了すると5になる。これを待ってから実行継続とする）
  if (strncmp(scrCommand,"DIAG1483",strlen(scrCommand))==0) {
    write("ダイアグ1483送信");
    // コマンド実行を止める
    isMsg1483FromScript = 1; // スクリプトからの呼び出し
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    outputExtMsg1483();
    return 0;
  }
  //------------------------------ラスト画初期化コマンドここから----------------------------------------------------
  //// INIT_VIEW ラスト画初期化
  
  if (strncmp(scrCommand,"INIT_VIEW",strlen(scrCommand))==0) {
    write("INIT_VIEW:コマンド読み読み");
    
    waitA0 = 0; waitA1 = 0;waitA3 = 0;waitA4 = 0;//パネル経由の呼び出しを止める
    
    cancelTimer(msExecInterval);//コマンド実行を止める
    alive_msExecInterval = 0;
    
     //取得状態を未取得に戻す 初期化
    sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,-1);
    updateLastBackViewText(-1);
    sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,-1);
    updateLastFrontViewText(-1);
    sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,-1);
    updateAutoDispMode(-1);
    sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,-1);
    updateCameraViewAutoOff(-1);
    
     //取得開始
    initViewActive = 1;
    initTargetView = 0;
    
     //outputDiagReq(0xA0);  // DID送信   outputDIDReq()にする。
     //write("INIT_VIEW : send DID 13A0");
    write("INIT_VIEW start");
    initview();
    write("INIT_VIEW end");
    return 0;
  }
 //------------------------------ラスト画初期化コマンドここまで----------------------------------------------------
  
  write("不正なコマンドがありました。%s",scrCommand);
  return 0;
}

on timer msRecordingCommand {
  int recordingResult;

  cancelTimer(msRecordingCommand);
  recordingResult = ReadRecordingCommandResult();
  if (recordingResult == 1) {
    alive_msRecordingCommand = 0;
    write("[REC_TIMELINE] OperationId=%s Event=CAPL_RESULT_RECEIVED State=%s Reason=%s TimeNow=%d",
          RecordingOperationId,RecordingResultState,RecordingResultReason,timeNow());
    write("[REC_TIMELINE] OperationId=%s Event=CAPL_NEXT_COMMAND TimeNow=%d",
          RecordingOperationId,timeNow());
    setTimer(msExecInterval,0);
    alive_msExecInterval = 1;
    return;
  }
  if (recordingResult == -1) {
    alive_msRecordingCommand = 0;
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    ShowCommand("録画処理失敗",RecordingExpectedCommand,RecordingResultReason);
    write("[REC_TIMELINE] OperationId=%s Event=CAPL_RESULT_FAILED Reason=%s TimeNow=%d",
          RecordingOperationId,RecordingResultReason,timeNow());
    return;
  }

  RecordingWaitElapsedMs = RecordingWaitElapsedMs + 100;
  if (RecordingWaitElapsedMs >= RecordingWaitTimeoutMs) {
    alive_msRecordingCommand = 0;
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    sysSetVariableString(sysvar::VERI::RecordingCommandState,"FAILED");
    sysSetVariableString(sysvar::VERI::RecordingCommandReason,"CAPL_RESULT_TIMEOUT");
    ShowCommand("録画処理失敗",RecordingExpectedCommand,"CAPL_RESULT_TIMEOUT");
    write("[REC_TIMELINE] OperationId=%s Event=CAPL_RESULT_TIMEOUT TimeNow=%d",
          RecordingOperationId,timeNow());
    return;
  }

  setTimer(msRecordingCommand,100);
  alive_msRecordingCommand = 1;
}


on timer msOnNinCameraTimer {
  setSignal(G5M::CDC_5::AVN1S78::DS_INST1,0);
  setSignal(G5M::CDC_5::AVN1S78::DS_INST2,0);
  setSignal(G5M::CDC_5::AVN1S78::DS_INST3,0);
  setSignal(G5M::CDC_5::AVN1S78::DS_INST4,0);
  setSignal(G5M::CDC_5::AVN1S78::DS_INST5,0);
  setSignal(G5M::CDC_5::AVN1S78::DS_FUNID,0x0);
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msOnNinCameraTimer);
  alive_msOnNinCameraTimer = 0;
}


on timer msDiagTimer {
  setSignal(G2M1::CDC21::AVN1S73::DI_MODE,0);
  setSignal(G2M1::CDC21::AVN1S73::CMD_MODE,1);
  setSignal(G2M1::CDC21::AVN1S73::MMD_MODE,1);
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msDiagTimer);
  alive_msDiagTimer = 0;
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::sysRead
  概要  TEST_EXECパネルの再生ボタン（三角）の処理を実行します。 単一スクリプトの実行の入口
  詳細  TEST_EXECパネルの再生ボタンを押下した時に、システム変数VERI::sysReadが0→1に変化し、このハンドラが呼ばれる
        再生ボタンの左側のファイル名(VERI::ScriptFile)を読み出し、関数ExecScript(InputScriptFile）へ渡します
******************************************************************************************/
on sysvar VERI::sysRead { // Read and RUN ボタン押下
  if(sysGetVariableInt(sysvar::VERI::sysRead)==0 || ScriptFileOpened==1) {
    return; // Readボタンを離したとき、または、ファイルをすでに開いているときにReadボタンが押されても何もしない　（連打防止）
  }
  sysGetVariableString(sysvar::VERI::ScriptFile,InputScriptFile,elcount(InputScriptFile));
  write("TestScript:%s",InputScriptFile);
  ExecScript(InputScriptFile);
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::Pause
  概要  TEST_EXECパネルのPauseボタン(トグルスイッチ) の処理を実行します。 実行中のスクリプトを中断／再開します
  詳細  TEST_EXECパネルのPauseボタンをONにすると、自動実行に関するタイマーをキャンセルします。
        TEST_EXECパネルのPauseボタンをOFFにすると、自動実行に関するタイマーを再開させます。
          この処理をさせるために、自動実行部分で使用させるすべてのタイマーには、Alive_(タイマー名)の変数を割り当ててあり
          Alive_(タイマー名)の変数が1で、ポーズをかけた場合にそのタイマーをキャンセル、ポーズ解除でタイマーをセットします。
          タイマーにセットする値は初期値またはおおよその値になります。
******************************************************************************************/
on sysvar VERI::Pause { // Pauseボタン
  if (sysGetVariableInt(sysvar::VERI::Pause)==1) { //　実行中のタイマーを止める
    if (alive_msExecInterval == 1) {
      cancelTimer(msExecInterval);
    } 
    if (alive_msRecordingCommand == 1) {
      cancelTimer(msRecordingCommand);
    }
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
//    if (alive_msWaitTimer == 1) {
//      cancelTimer(msWaitTimer);
//    }
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
    if (alive_msRespTimer == 1) {
      cancelTimer(msRespTimer);
    }
    if (alive_msDiagTimer == 1) {
      cancelTimer(msDiagTimer);
    }
    if (alive_msMultiScript == 1) {
      cancelTimer(msMultiScript);
    }
    if (alive_msIGN_ON_Timer ==1) {
      cancelTimer(msIGN_ON_Timer);
    }
    if (alive_msOnNinCameraTimer == 1) {
      cancelTimer(msOnNinCameraTimer);
    }
    if (alive_msCAMERA_SW_Timer == 1) {
      cancelTimer(msCAMERA_SW_Timer);
    }
  } else {  // 止まっていたタイマーを動かす
    if (alive_msExecInterval == 1) {
      setTimer(msExecInterval,CommandInterval);
    } 
    if (alive_msRecordingCommand == 1) {
      setTimer(msRecordingCommand,100);
    }
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
//    if (alive_msWaitTimer == 1) {
//      setTimer(msWaitTimer,msWaitTicks);
//    }
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
    if (alive_msRespTimer == 1) {
      setTimer(msRespTimer,1);
    }
    if (alive_msDiagTimer == 1) {
      setTimer(msDiagTimer,100);
    }
    if (alive_msMultiScript ==1) {
      setTimer(msMultiScript, 1);
    }
    if (alive_msIGN_ON_Timer == 1) {
      setTimer(msIGN_ON_Timer,6);
    }
    if (alive_msOnNinCameraTimer == 1) {
      setTimer(msOnNinCameraTimer,1);
    }
    if (alive_msCAMERA_SW_Timer == 1) {
      setTimer(msCAMERA_SW_Timer,6);
    }
  }
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::execStop
  概要  TEST_EXECパネルのSTOPボタン(■のラベルのスイッチ) の処理を実行します。 実行中のスクリプトを停止します。
        再開はできません。
  詳細  TEST_EXECパネルのSTOPボタン(■のラベルのスイッチ)を押すとこのハンドラが呼ばれます。
        自動実行で使用中のタイマーをすべてキャンセルし、開いているファイルハンドルをすべてクローズします。
        このボタンを押した場合に、自動実行の状態がどのようになっているかわからないため、CANoeの実行を止めることをお勧めします。
******************************************************************************************/
on sysvar VERI::execStop { //ストップボタン
    ShowCommand("強制終了","","CANoe 停止→開始を推奨");
    if (alive_msExecInterval == 1) {
      alive_msExecInterval = 0;
      cancelTimer(msExecInterval);
    } 
    if (alive_msRecordingCommand == 1) {
      alive_msRecordingCommand = 0;
      cancelTimer(msRecordingCommand);
    }
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
//    if (alive_msWaitTimer == 1) {
//      alive_msWaitTimer = 0;
//      cancelTimer(msWaitTimer);
//    }
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
    if (alive_msRespTimer == 1) {
      alive_msRespTimer = 0;
      cancelTimer(msRespTimer);
    }
    if (alive_msDiagTimer == 1) {
      alive_msDiagTimer = 0;
      cancelTimer(msDiagTimer);
    }
    if (alive_msMultiScript == 1) {
      alive_msMultiScript = 0;
      cancelTimer(msMultiScript);
    }
    if (alive_msIGN_ON_Timer == 1) {
      alive_msIGN_ON_Timer = 0;
      cancelTimer(msIGN_ON_Timer);
    }
    if (alive_msCAMERA_SW_Timer == 1) {
      alive_msCAMERA_SW_Timer = 0;
      cancelTimer(msCAMERA_SW_Timer);
    }
    if (ScriptFileOpened == 1) {
      ScriptFileOpened = 0;
      fileClose(ScriptFileHandle);
    }
    if (FileListOpened == 1) {
      FileListOpened = 0;
      fileClose(FileListHandle);
    }
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::sysReadFolder
  概要  TEST_EXECパネルのFolderRead and Run ボタンの処理実行をします。複数スクリプト実行の入口になります。
  詳細  TEST_EXECパネルのFolderRead and Run ボタンを押下/離すと、システム変数VERI::sysReadFolderが変化し、
        このハンドラが呼ばれます。FolderRead and Runボタンの左側のフォルダ名(VERI::sysInputFolder)を読み出し、
        これをフォルダ名として、そのフォルダの中の0000.filelist.txtを、スクリプトリストとしてオープンします。
        ファイルアクセスに時間がかかりそうなので、いったんイベントハンドラを抜けるために、タイマーmsMultiScriptをセットして、
        このハンドラを抜けます。
******************************************************************************************/
on sysvar VERI::sysReadFolder { // Folder Read and RUN ボタン押下
  if(sysGetVariableInt(sysvar::VERI::sysReadFolder)==0 || FileListOpened==1) {
    return; // Readボタンを離したとき、または、0000.FileList.txtをすでに開いているときにReadボタンが押されても何もしない　（連打防止）
