on start {
  sysSetVariableInt(sysvar::VERI::BA_ON,0);
  sysSetVariableInt(sysvar::VERI::IG_ON,0);
  sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,-1);
  updateLastBackViewText(-1);
  sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,-1);
  updateLastFrontViewText(-1);
  sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,-1);
  updateAutoDispMode(-1);
  sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,-1);
  updateCameraViewAutoOff(-1);
  ScriptFileOpened = 0;
  alive_msMultiScript = 0;
  CommandInterval = 0; //僐儅儞僪偺幚峴娫妘 曄峏偡傞偵偼丄interval 僐儅儞僪偱曄峏
  openPanel("TEST_EXEC");
  sysSetVariableInt(sysvar::VERI::TouchPanelAvailable,0); // 僞僢僠僷僱儖柍岠
  // Piggy愱梡偲偡傞丅埲壓幚巤2025/9/4 (VH傪奜偡乯
  //  侾乯CANoe愝掕曄峏丗  僥僗僩丗僥僗僩娐嫬偐傜丄PowerControl傪奜偡
  //  俀乯埲壓俀峴傪捛壛
//  sysSetVariableInt(sysvar::VERI::VHorIOpiggy,1); // VH偑愙懕偝傟偰側偄応崌丄I/O piggy偑偁傞傕偺偲偟偰摦嶌偝偣傞
//  write("I/O piggy偲偟偰摦嶌");
  write("偁偁偁");
}


/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::ScriptFile
  奣梫  TEST_EXEC僷僱儖偺僗僋儕僾僩僼傽僀儖傪巜掕偡傞PathDialog僐儞僩儘乕儖偵暿偺僗僋儕僾僩僼傽僀儖偑巜掕偝傟偨応崌偵丄僼傽僀儖傪僋儘乕僘偟傑偡丅
  徻嵶  僗僋儕僾僩僼傽僀儖傪巜掕偡傞PathDialog(僼傽僀儖柤昞帵偲僼傽僀儖傪巜掕偡傞儃僞儞傪慻傒崌傢偣偨傕偺乯偱丄
        暿僼傽僀儖傪巜掕偟偨応崌偵偙偺僴儞僪儔偑屇偽傟傞偺偱丄奐偄偰偄偨僗僋儕僾僩僼傽僀儖偺僼傽僀儖僴儞僪儖傪僋儘乕僘偟傑偡丅
******************************************************************************************/
on sysvar VERI::ScriptFile {  // 僗僋儕僾僩僼傽僀儖偑曄傢偭偨傜丄僼傽僀儖傪暵偠傞
  fileClose(ScriptFileHandle);
  ScriptFileOpened=0;
}

//on sysvar VERI::sysInputFolder { // 擖椡僼僅儖僟偑曄傢偭偨傜丄FileList 傪暵偠傞
  
//--------------------------------------------------------------------------------
// 娭悢 ReadScript 
//    摦嶌丗Buffer[]偵撉傒崬傒嵪傒偺僗僋儕僾僩偺侾峴傪僐儅儞僪偲僷儔儊乕僞偵暘夝偡傞
//    栠傝抣丗1: 惓忢偵暘夝偱偒偨丅 0: 僐儅儞僪堎忢
//    堷悢丗側偟
//    徻嵶丗僌儘乕僶儖曄悢 Buffer[]偺拞恎傪丄僞僽嬫愗傝偱俁偮偵暘夝偟丄
//         偦傟偧傟傪僌儘乕僶儖曄悢 scrCommand[],scrParam1[],scrParam2[]偵奿擺偡傞丅
//--------------------------------------------------------------------------------
void ReadScript() {  // 僌儘乕僶儖曄悢Buffer偵撉傒崬傫偩僗僋儕僾僩侾峴偺暥帤楍張棟
  t=0;
  write("scrBuffer偺僒僀僘 %d",strlen(scrBuffer));
  scrCommand[0] = 0x00;
  scrParam1[0] = 0x00;
  scrParam2[0] = 0x00;
  for (r=0;r<elcount(scrCommand);r++) { //僐儅儞僪愗傝弌偟 ---------------------------------------------------
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)){
      break;
    }
    if ((scrBuffer[t]>0x60)&&(scrBuffer[t]<0x7B)) { //僐儅儞僪傪戝暥帤偵偡傞
      scrCommand[r]=scrBuffer[t]-0x20;
    } else {
      scrCommand[r]=scrBuffer[t];
    }
    t++;
  }
  if (r >= elcount(scrCommand)) {
    r=elcount(scrCommand)-1;  // r偑攝楍挿偝埲忋偵側偭偨応崌丄r傪椞堟僒僀僘偺嵟屻傪偝偡傛偆偵偡傞丅丂乮scrCommand傪嵟戝挿偱愗傞乯
  }
  scrCommand[r]=0x00;
  t++; //丂scrBuffer[t]偑Tab傪偝偟偰偄傞偺偱師傊
  if (t >= strlen(scrBuffer)){  // t偑撉傒崬傒Buffer椞堟埲忋偵側偭偨応崌
    write("Command撉傒崬傒堎忢 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  for (r=0;r<elcount(scrParam1);r++) { //僷儔儊乕僞侾愗傝弌偟 -------------------------------------------------
    if (t >= strlen(scrBuffer)) { break ; } // t偑撉傒崬傒暥帤楍埲忋偵側偭偨傜張棟掆巭 
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)){
      break;
    }
    scrParam1[r]=scrBuffer[t];
    t++;
  }
  if (r >= elcount(scrParam1)) {
    r=elcount(scrParam1)-1;  // r偑攝楍挿偝埲忋偵側偭偨応崌丄r傪椞堟僒僀僘偺嵟屻傪偝偡傛偆偵偡傞丅丂乮scrParam1傪嵟戝挿偱愗傞乯
  }
  scrParam1[r]=0x00;
  t++; //丂scrBuffer[t]偑Tab傪偝偟偰偄傞偺偱師傊
  if (t >= strlen(scrBuffer)){  // t偑Buffer椞堟埲忋偵側偭偨応崌
    write("Param1撉傒崬傒堎忢 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  for (r=0;r<elcount(scrParam2);r++) { //僷儔儊乕僞2愗傝弌偟 --------------------------------------------------
    if (t >= strlen(scrBuffer)) { break ; } // t偑撉傒崬傒暥帤楍埲忋偵側偭偨傜張棟掆巭 
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)||scrBuffer[t]==0x00){
      break;
    }
    scrParam2[r]=scrBuffer[t];
    t++;
  }
  if (t > strlen(scrBuffer)){  // t偑Buffer椞堟埲忋偵側偭偨応崌
    write("Param2撉傒崬傒堎忢 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  if (r >= elcount(scrParam2)) {
    r=elcount(scrParam2)-1;  // r偑攝楍挿偝埲忋偵側偭偨応崌丄r傪椞堟僒僀僘偺嵟屻傪偝偡傛偆偵偡傞丅丂乮scrParam1傪嵟戝挿偱愗傞乯
  }
  scrParam2[r]=0x00;
  write ("Read %s, %s, %s",scrCommand,scrParam1,scrParam2);
  return ;
}

//--------------------------------------------------------------------------------
// 娭悢 dispatch() 
//    摦嶌丗僌儘乕僶儖曄悢scrCommand[]偵奿擺偝傟偨僐儅儞僪偵傛偭偰丄偦傟偧傟偺張棟傪幚峴偡傞丅
//    栠傝抣丗 int  1: 師偺僗僋儕僾僩峴偺幚峴偵偡偡傓丅丂CommandInterval懸偭偰偐傜幚峴
//                      屇傃弌偟尦偼丄師偺峴偺幚峴偺偨傔僗僋儕僾僩幚峴僞僀儅乕偺僙僢僩傪偡傞乯
//                 0: 師偺僗僋儕僾僩偺峴偺幚峴偵恑傫偱偼僟儊丅
//                      杮娭悢偺拞偱丄師偺張棟乮僂僃僀僩懸偪傗丄僐儅儞僪庴怣乯偺僞僀儅乕傪僙僢僩偡傞
//                      屇傃弌偟尦偼僗僋儕僾僩幚峴僞僀儅乕偺僙僢僩偼偟側偄丅
//                 2: 師偺僗僋儕僾僩偺峴偺幚峴傪懄帪屇傃弌偟
//    堷悢丗側偟
//--------------------------------------------------------------------------------

int dispatch() { //栠傝抣侾偼師偺僐儅儞僪懸偪傊丅侽偼師偺僐儅儞僪傪懸偨側偄乮僂僃僀僩丄傕偟偔偼僄儔乕廔椆乯
  // "BA" :  +B偺ON/OFF惂屼  VH:V30, IOPiggy:DOUT0 
  if (strncmp(scrCommand,"BA",strlen(scrCommand))==0) { // BA
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { //                                                // IO piggy 偱摦嶌偟偰偄傞応崌
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,1);
      return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {  
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,0);
      return 1;
    } 
    write ("BA偺堷悢晄惓");
    return 0;
  } 
  if  (strncmp(scrCommand,"IGN",strlen(scrCommand))==0) { // IGN
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { //                                // IO piggy偱摦嶌
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,1) ;
        return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,0) ;
      return 1;
    }
    write ("IGN偺堷悢晄惓");
    return 0;
  } 
  if ((strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0)||(strncmp(scrCommand,"WaitMS",strlen(scrCommand))==0)) {
//伀---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------

  // WaitMS偺応崌偺僐儅儞僪僀儞僞乕僶儖傪側偔偡偨傔偺懳嶔丂2026/1/16
  // WaitMS愱梡僞僀儅乕msWaitTimer傪巊偆偺偱偼側偔丄msExecInterval偺屇傃弌偟帪娫偱Wait傪偐偗傞傕偺偲偡傞
  // 偙偺偨傔丄Dispatch撪偱偺WAITMS偺張棟偼晄梫丂傑偨丄師偺峴傪懄帪幚峴偡傞偨傔偵丄2傪曉偡傛偆偵偟偨丅
    // 師偺峴傪撉傓
    //cancelTimer(msExecInterval);
    //alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    msWaitTicks = atol(scrParam1);
    write("Wait %d",msWaitTicks);
    //setTimer(msWaitTimer,msWaitTicks);
    //alive_msWaitTimer = 1;
    //return 0; //僐儅儞僪懸偪傪巭傔傞丅  
    return 2;  // 2丗師偺僐儅儞僪傪懄帪幚峴
//仾---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------
  }
//伀---僔僌僫儖偺弴彉懳墳丂260130
  if (strncmp(scrCommand,"P_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,6);
    return 1;
  }
  if (strncmp(scrCommand,"R_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,5);
    return 1;
  }
  if (strncmp(scrCommand,"N_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 3);  
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    return 1;
  }
  if (strncmp(scrCommand,"D_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4);  
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,3);
    return 1;
  }
  if (strncmp(scrCommand,"LIGHT",strlen(scrCommand))==0) {
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      setSignal(G2M1::CDC21::AVN1S73::DN_DISP,1);
      return 1;
    } 
