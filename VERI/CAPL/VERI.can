on timer msMultiScript {
  n=fileGetString(ScrFileName,elCount(ScrFileName),FileListHandle);
  for (t=0;t<elcount(ScrFileName);t++) { 
    if (ScrFileName[t]==0x0a) { ScrFileName[t]=0x00; }
  }
//  write("msMultiScript Handler %d",n);
  if (n==0) { // 0偑婣偭偰偒偨傜FileList偺廔抂
    ShowCommand("楢懕幚峴廔椆","","");
    write("~~~楢懕幚峴廔椆~~~");
    cancelTimer(msMultiScript);
    alive_msMultiScript = 0;
    MultiScriptMode = 0;
    fileClose(FileListHandle);
    FileListOpened = 0;
    return;
  }
  snprintf(InputScriptFile,elcount(InputScriptFile),"%s\\%s",InputFolder,ScrFileName);
  CancelTimer(msMultiScript);
  alive_msMultiScript = 0;
  write("%s",ScrFileName);
  write("TestScript:%s",InputScriptFile);
  ExecScript(InputScriptFile);
}

//--------------------------------------------------------------------------------
// 娭悢 execScript( 僗僋儕僾僩僼傽僀儖柤 ) 
//    摦嶌丗堷悢偱搉偝傟偨僗僋儕僾僩僼傽僀儖傪奐偄偰丄僐儅儞僪幚峴廃婜INTERVAL僐儅儞僪偑擖偭偨侾峴栚傪撉傒弌偟丄僐儅儞僪幚峴廃婜傪僙僢僩偟丄俀峴栚埲崀偺僗僋儕僾僩傪幚峴偝偣傞丅
//    栠傝抣丗 側偟
//    堷悢丗僗僋儕僾僩僼傽僀儖柤
//--------------------------------------------------------------------------------
void ExecScript(char ScriptFileName[]) { // 堷悢偱庴偗庢偭偨僗僋儕僾僩僼傽僀儖傪幚峴偡傞丅
  write ("ExecScript %s",ScriptFileName);
  ScriptFileHandle = openFileRead(ScriptFileName,0); //  ASCII儌乕僪偱僼傽僀儖傪奐偔
  if (ScriptFileHandle==0) {
    write("僗僋儕僾僩僼傽僀儖 %s偑奐偗傑偣傫 %d",ScriptFileName, ScriptFileHandle);
  }
  ScriptFileOpened = 1;
  n=fileGetString(scrBuffer,elCount(scrBuffer),ScriptFileHandle);
  if (n==0) {
    write("僗僋儕僾僩僼傽僀儖偑撉傔傑偣傫");
  }
  ReadScript();
  ShowCommand(scrCommand,scrParam1,scrParam2);
  if (strncmp(scrCommand,"INTERVAL",strlen(scrCommand))==0) {
    CommandInterval=atol(scrParam1); // 傎傫偲偼Param1偺斖埻傪僠僃僢僋偟偨傎偆偑傛偄丅嵟弶偵愨懳偵InterVal傪擖傟傞丅侾峴栚傪撉傒旘偽偟偰偟傑偆偨傔
    write("INT: %d",CommandInterval);
  }
  sysSetVariableInt(sysvar::VERI::CMDITVL, CommandInterval);
//伀---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------
  // WaitMS偺応崌偺僐儅儞僪僀儞僞乕僶儖傪側偔偡偨傔偺懳嶔丂2026/1/16
  // 師偺峴傪撉傓
  n=fileGetString(scrBuffer,elcount(scrBuffer),ScriptFileHandle);
  CommandStored = n; //僐儅儞僪撉傒崬傒寢壥
  if (n==0) {
    write("Interval僐儅儞僪偺師偺峴偑撉傔傑偣傫");
  }
  ReadScript();
  ShowCommand(scrCommand,scrParam1,scrParam2);
  if (strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0) {
    //msWaitTicks = atol(scrParam1);
    //write("WAITMS: %d",msWaitTicks);
    setTimer(msExecInterval,0);
    alive_msExecInterval = 1;
    return;
  }
//仾---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------
  settimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
}

//--------------------------------------------------------------------------------
// 娭悢 ShowCommand( 僐儅儞僪暥帤楍丄僷儔儊乕僞侾暥帤楍丄僷儔儊乕僞俀暥帤楍 ) 
//    摦嶌丗堷悢偱搉偝傟偨僐儅儞僪暥帤楍丄僷儔儊乕僞侾暥帤楍丄僷儔儊乕僞俀暥帤楍傪丄CANoe偺Write僂傿儞僪僂偵弌椡偡傞乮摦嶌妋擣梡乯
//    栠傝抣丗 側偟
//    堷悢丗僐儅儞僪暥帤楍丄僷儔儊乕僞侾暥帤楍丄僷儔儊乕僞俀暥帤楍
//--------------------------------------------------------------------------------

void ShowCommand(char mycmd[],char myp1[], char myp2[]) {
  sysSetVariableString(sysvar::VERI::cmd,mycmd);
  sysSetVariableString(sysvar::VERI::param1,myp1);
  sysSetVariableString(sysvar::VERI::param2,myp2);
}


on timer msExecInterval {
//伀---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------

  if (CommandStored == 0) { // 僐儅儞僪偑撉傒崬傒嵪傒側傜Dispatch傪幚峴偡傞丂260204
    write("~~~抶墑幚峴廔椆~~~");
    canceltimer(msExecInterval);
    alive_msExecInterval = 0;
    return;
  }
  currentMyTime = timeNow()/100000.0 ;
  write ("仧%f仧Execute %s, %s, %s",currentMyTime,scrCommand,scrParam1,scrParam2);
  ShowCommand(scrCommand,scrParam1,scrParam2);
  NextInterval = dispatch(); // 僐儅儞僪幚峴 栠傝抣偑侾偱側偗傟偽僂僃僀僩偐幚峴僄儔乕側偺偱師偺幚峴僞僀儅乕偺懸偪偵偼擖傜側偄
     //NextInterval dispatch偺栠傝抣
     //             0: 僐儅儞僪僀儞僞乕僶儖僞僀儅乕僙僢僩偟側偄乮暿偺僞僀儅乕偑嶌摦拞乯
     //             1: 僐儅儞僪僀儞僞乕僶儖僞僀儅乕傪丄CommandInterval偱僙僢僩偡傞乮師偺僐儅儞僪幚峴傪懸偮乯
     // 丂丂丂丂丂丂 2: 僐儅儞僪僀儞僞乕僶儖僞僀儅乕傪丄0偱僙僢僩偡傞丅懄帪屇傃弌偟 (dispatch偱WAITMS傪幚峴偟偨帪偺栠傝抣乯
  // 師偺峴撉傒崬傒
  // NextInterval偑0偱婣偭偰偒偰傕師偺峴傪撉傒崬傫偱偟傑偭偰偄傞丅梫専摙
  n=fileGetString(scrBuffer,elCount(scrBuffer),ScriptFileHandle);
  CommandStored = n; // 僐儅儞僪撉傒崬傒寢壥丂260206
  if (n==0) { // 0偑婣偭偰偒偨傜僼傽僀儖廔抂
    ShowCommand("廔椆","","");
    write("~~~廔椆~~~");
    ScriptFileOpened = 0;
    fileClose(ScriptFileHandle);
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    if ( MultiScriptMode== 1) { // 暋悢僼傽僀儖幚峴拞偺応崌師偺僼傽僀儖撉傒崬傒
      setTimer(msMultiScript,1);
      alive_msMultiScript = 1;
    }
    return ;
  }
  ReadScript(); // 僐儅儞僪暘夝
  if (strlen(scrCommand) == 0) {  // 嬻峴撉傒崬傒帪傕廔椆
    write("~~~嬻峴撉傒崬傒 幚峴廔椆~~~");
    CommandStored = 0;
    canceltimer(msExecInterval);
    alive_msExecInterval = 0;
    return;    
  }
//  write("%d",strlen(scrCommand));
  write("%d%",NextInterval);
  switch (NextInterval){
    case 1:                        //1: 師偺峴傪幚峴丅師峴偑WAITMS側傜懄幚峴丄捠忢峴側傜CommandInterval懸偪
      write("偙偙偼1偽傫");
      if (strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0) { //師偺峴偑WAITMS偺帪偺張棟
        write("WAITMS偺傎偆");
        settimer(msExecInterval,0);
        alive_msExecInterval = 1;
      } else {
        write("WAITMS偠傖側偄傎偆");
        settimer(msExecInterval,CommandInterval);
        alive_msExecInterval = 1;
      }
      return;
    case 2:                      //2: WAITMS幚峴偺栠傝抣丅師峴偑捠忢丒WAITMS偳偪傜偱傕msWaitTicks懸偪
      settimer(msExecInterval,msWaitTicks);
      alive_msExecInterval = 1;
      return;
    case 0:                     //0: 師偺峴偼幚峴偟側偄乮暿僞僀儅乕偱庴怣乯
      canceltimer(msExecInterval);
      alive_msExecInterval = 0;
      return;
    default:
      canceltimer(msExecInterval);
      alive_msExecInterval = 0;
      return;
  }

//仾---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------
}

//伀---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------
/*on timer msWaitTimer{
//  write("msWaitTimer僴儞僪儔");
  setTimer(msExecInterval,0);
  alive_msExecInterval = 1;
  cancelTimer(msWaitTimer);
  alive_msWaitTimer = 0;
}
*/
//仾---WaitMS僐儅儞僪偱丄僐儅儞僪幚峴懸偪偲Wait帪娫傪椉曽懸偭偰偟傑偆偨傔丄僐儅儞僪幚峴懸偪傪僂僃僀僩帪娫偵曄峏------260116------

on timer msIGN_ON_Timer {
//  write("msIGN_ON_Timer");
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msIGN_ON_Timer);
  alive_msIGN_ON_Timer = 0;
}

on timer msCAMERA_SW_Timer {
//  write("msCAMERA_SW_Timer");
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msCAMERA_SW_Timer);
  alive_msCAMERA_SW_Timer = 0;
}

on timer msRespTimer{
  putValue(EnvSID31_Tx_IOL,0);  
  putValue(EnvSID31_Tx_PVM,0);  
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msRespTimer);
  alive_msRespTimer = 0;
}

