// VH摦嶌帪偼丄VH偺V31偺弌椡懁偺GND傪巊偭偰丄僇儊儔SW偺I/O惂屼偵偟偰偄傞丅 V31偺擖椡懁偺GND偵丄ADU偺GND傪愙懕
// IO Piggy 摦嶌帪偼丄DOUT2偺ON/OFF偲偡傞
/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::GND_ON
  奣梫  VERI僷僱儖偺GND偺僩僌儖儃僞儞丄僇儊儔SW乮暔棟乯偲偄偆儔儀儖偺張棟幚峴傪偟傑偡丅
        僴乕僪僂僃傾偺僇儊儔僗僀僢僠乮VIEWSW乯偺ON/OFF傪偟傑偡丅
  徻嵶  VH1160傪巊偭偨僔僗僥儉偲丄I/OPiggy傪巊偭偨僔僗僥儉偱摦嶌偑曄傢傝傑偡丅
        VH1160偺応崌丄僔僗僥儉曄悢VHDevice::Relay::Relay_V31 偵丄RELAY_STATE_CLOSE 傑偨偼丄RELAY_STATE_OPEN傪僙僢僩偟傑偡丅
        偙傟偵傛傝丄僥僗僩儌僕儏乕儖PowerControl偲偟偰慻傒崬傑傟偨儌僕儏乕儖偺拞偱丄偙偺僔僗僥儉曄悢傪尒偰丄
        VH1160偺儕儗乕31(IGN, IG偲偟偰巊梡乯傪僋儘乕僘乮ON乯傑偨偼丄僆乕僾儞乮OFF)偵偟傑偡丅(31抂巕偲31'抂巕偺娫偺僋儘乕僘乛僆乕僾儞乯
        僔僗僥儉愙懕偵偍偄偰偼丄31抂巕偵ADU偺GND傪丄31'抂巕偵ADU偺僇儊儔SW偺攝慄傪愙懕偟傑偡丅
        I/OPiggy偺応崌丄僔僗僥儉曄悢IO::IOPiggy1::DOUT2 偵丄侾(ON) 傑偨偼 0(OFF)傪僙僢僩偟傑偡丅
        DOUT2傪SSR偺INPUT懁(僐僀儖懁乯偵愙懕偟丄SSR偺OUTPUT懁乮愙揰懁乯傪掕揹埑揹尮偺IG偲ECU偺僇儊儔SW偺攝慄偺娫偵擖傟傞偙偲偱丄
        僇儊儔俽倂偺ON/OFF惂屼傪峴偄傑偡丅
******************************************************************************************/
on sysvar sysvar::VERI::GND_ON { // PVMSW儃僞儞
  if (sysGetVariableInt(sysvar::VERI::GND_ON)==1) { // 儃僞儞墴壓 墴偟偨偲偒
/*    
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_CLOSE);
    } else { // for IO piggy
*/
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,1);
/*
    }
*/
  }else{                                            // 儃僞儞榖偡
/*
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_OPEN);
    } else {
*/
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,0);
/*
    }      
*/
  }
}
/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::SHIFT_P
  奣梫  VERI僷僱儖偺Parking偲偄偆儔儀儖偺儃僞儞偺張棟幚峴傪偟傑偡丅 挀幵儌乕僪偒傝偐偊
  徻嵶  僔僼僩偵娭偡傞僔僗僥儉曄悢偺憖嶌偺傒幚峴偟傑偡丅幚嵺偵CAN怣崋傪弌偡偺偼丄傕偲傕偲偺CFG僼傽僀儖偱幚峴偝傟傑偡丅
        僔僌僫儖 ZN11S0::REV_SW       仺 0
        僔僗僥儉曄悢 ECT1G01_B_PRNDB   仺 侾
******************************************************************************************/
on sysvar sysvar::VERI::SHIFT_P { //丂僔僼僩P
  if (sysGetVariableInt(sysvar::VERI::SHIFT_P)==0) {
    return;   
  }
  sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
  setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
  setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,6);
}

