/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::CC10
  奣梫  VERI僷僱儖偺僙儞僞乕僨傿僗僾儗僀昞帵僒僀僘偺僒僀僘愝掕儃僞儞偺張棟幚峴傪偟傑偡丅
  徻嵶  儃僞儞偺嵍偺僥僉僗僩儃僢僋僗偺抣傪撉傒崬傒丄娐嫬曄悢SigDt_AVN1S73_CD_SIZE傊奿擺
        嬶懱揑偵偼PVM_Panel偺巇條忣曬偺僙儞僞乕僨傿僗僾儗僀僒僀僘偺僪儘僢僾僟僂儞偺抣偑曄傢傝傑偡丅丅
******************************************************************************************/
on sysvar sysvar::VERI::CC10 { // 僙儞僞乕僨傿僗僾儗僀僒僀僘丂1010b:1280x621(10.5in)
  if (sysGetVariableInt(sysvar::VERI::CC10)==0) { return; }
  screensize=sysGetVariableInt(sysvar::VERI::GamenSize);
  putValue(SigDt_AVN1S73_CD_SIZE,screensize);
}

