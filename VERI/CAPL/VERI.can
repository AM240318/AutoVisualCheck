  if(v == 0) {
    sysSetVariableString(sysvar::VERI::DID::LastFrontViewText,"儚僀僪僼儘儞僩價儏乕");
  } else if(v == 1){
    sysSetVariableString(sysvar::VERI::DID::LastFrontViewText,"僒僀僪僋儕傾儔儞僗價儏乕");
  } else {
    sysSetVariableString(sysvar::VERI::DID::LastFrontViewText,"枹庢摼");
  }
}

