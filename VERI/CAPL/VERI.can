/*****************************************************************************************
システム変数イベントハンドラ  VERI::SiyouJoho
  概要  VERIパネルの"DA03仕様情報切替"ボタンを押した時の処理。SID31_IOLパネルの操作を環境変数を介して実施し、仕様情報切替コマンドを送信します。
******************************************************************************************/
on sysvar sysvar::VERI::SiyouJoho { //仕様情報切替 
  if (sysGetVariableInt(sysvar::VERI::SiyouJoho)==0) {     
    putValue(EnvSID31_Tx_IOL,0);
    return; 
  }
    putValue(EnvSID31_RID_Tx_IOL, 0xDA03);
    putValue(EnvSID31_Type_IOL,1);
    putValue(EnvSID31_RspNecessity_IOL,0);
    putValue(EnvSID31_Tx_IOL,1);
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::TargetMarkerStart
  概要  VERIパネルの"1240ﾀｰｹﾞｯﾄﾏｰｶｰ認識開始"ボタンを押した時の処理。SID31_PVMパネルの操作を環境変数を介して実施し、ﾀｰｹﾞｯﾄﾏｰｶｰ認識開始要求コマンドを送信します。
******************************************************************************************/
on sysvar sysvar::VERI::TargetMarkerStart //1240　ターゲットマーカー認識開始要求
{
  if (sysGetVariableInt(sysvar::VERI::TargetMarkerStart)==0) {
    putValue(EnvSID31_Tx_PVM,0);  
    return; 
  }
    putValue(EnvSID31_RID_Tx_PVM, 0x1240);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::TargetMarkerForce
  概要  VERIパネルの"127Dﾀｰｹﾞｯﾄﾏｰｶｰ強制"ボタンを押した時の処理。SID31_PVMパネルの操作を環境変数を介して実施し、ﾀｰｹﾞｯﾄﾏｰｶｰ強制認識開始要求コマンドを送信します。
******************************************************************************************/
on sysvar sysvar::VERI::TargetMarkerForce //127D　ターゲットマーカー強制
{
  if (sysGetVariableInt(sysvar::VERI::TargetMarkerForce)==0) {
    putValue(EnvSID31_Tx_PVM,0);  
    return; 
  }
    putValue(EnvSID31_RID_Tx_PVM, 0x127D);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::ViewDataCreate
  概要  VERIパネルの"1241ビューデータ生成"ボタンを押した時の処理。SID31_PVMパネルの操作を環境変数を介して実施し、ビューデータ生成開始要求コマンドを送信します。
******************************************************************************************/
on sysvar sysvar::VERI::ViewDataCreate //1241 ビューデータ生成開始要求
{
  if (sysGetVariableInt(sysvar::VERI::ViewDataCreate)==0) {     
    putValue(EnvSID31_Tx_PVM,0);  
    return; 
  }
    putValue(EnvSID31_RID_Tx_PVM, 0x1241);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::HeadLight_ON
  概要  VERIパネルの"ヘッドライトON"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施し、シグナルDN_Disp(昼夜画状態通知)を”1b:夜”にします。
******************************************************************************************/
on sysvar sysvar::VERI::HeadLight_ON { // ﾍｯﾄﾞﾗｲﾄON
  if (sysGetVariableInt(sysvar::VERI::HeadLight_ON)==0) { return; }
  setSignal(G2M1::CDC21::AVN1S73::DN_DISP,1);
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::HeadLight_OFF
  概要  VERIパネルの"ヘッドライトON"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施し、シグナルDN_Disp(昼夜画状態通知)を”0b:昼”にします。
******************************************************************************************/
on sysvar sysvar::VERI::HeadLight_OFF { // ﾍｯﾄﾞﾗｲﾄOFF
  if (sysGetVariableInt(sysvar::VERI::HeadLight_OFF)==0) { return; }
  setSignal(G2M1::CDC21::AVN1S73::DN_DISP,0);
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::OFFROAD
  概要  VERIパネルの"オフロードON"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
******************************************************************************************/
on sysvar sysvar::VERI::OFFROAD { // オフロードモードターンアシストインジケータ駆動要求
  if (sysGetVariableInt(sysvar::VERI::OFFROAD)==0) {
    return;
  } else {
    putValue(SigDt_ENG1G90_B_OMODE,1);
    setSignal(G2M1::DDM21::VSC1G12::V_GXHR0,-0.43);
    setSignal(G2M1::DDM21::VSC1G12::V_GYHR0,-0.43);
    setSignal(G2M1::DDM21::VSC1G12::V_YR1HR0,-3.0);
  }
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::OFFROAD_OFF
  概要  VERIパネルの"オフロードOFF"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
******************************************************************************************/
on sysvar sysvar::VERI::OFFROAD_OFF { // オフロードモードターンアシストインジケータ駆動要求オフ
  if (sysGetVariableInt(sysvar::VERI::OFFROAD_OFF)==0) {
    return;
  } else {
    putValue(SigDt_ENG1G90_B_OMODE,0);
    setSignal(G2M1::DDM21::VSC1G12::V_GXHR0,-0.43);
    setSignal(G2M1::DDM21::VSC1G12::V_GYHR0,-0.43);
    setSignal(G2M1::DDM21::VSC1G12::V_YR1HR0,-3.0);
  }
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::Tozetsu
  概要  VERIパネルの"AVN1S20途絶"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施し
        AVNS1S20を途絶させます
******************************************************************************************/
on sysvar sysvar::VERI::Tozetsu { // AVNS1S20　通信途絶
  if (sysGetVariableInt(sysvar::VERI::Tozetsu)==0) {
    return;
  } else {
    sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S20::TIMINGS::EnableCyclic,0);
  }
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::Tozetsu
  概要  VERIパネルの"AVN1S20途絶"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
******************************************************************************************/
on sysvar sysvar::VERI::Tozetsu_OFF { // AVNS1S20　通信再開
  if (sysGetVariableInt(sysvar::VERI::Tozetsu_OFF)==0) {
    return;
  } else {
    sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S20::TIMINGS::EnableCyclic,1);
  }
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::Rev_SCR_SW_Psh
  概要  VERIパネルの"リバース画面切替 押"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
        バック画面上の、ワイドバック、ナローバックの切替ボタンを、タッチ座標のシグナルを使って操作する
******************************************************************************************/

  on sysvar sysvar::VERI::TOUCH::Rev_SCR_SW_Psh { // バック画切替 押す
  if (sysGetVariableInt(sysvar::VERI::TOUCH::Rev_SCR_SW_Psh) == 0) {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
    return ;
  }
  setSignal(G2M1::CDC21::AVN1S73::X_COORD,980);
  setSignal(G2M1::CDC21::AVN1S73::Y_COORD,260);
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::Rev_SCR_SW_Rel
  概要  VERIパネルの"リバース画面切替 離"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
        バック画面上の、ワイドバック、ナローバックの切替ボタンを、タッチ座標のシグナル送信します。
******************************************************************************************/
on sysvar sysvar::VERI::TOUCH::Rev_SCR_SW_Rel { // バック画切替　離す
  if (sysGetVariableInt(sysvar::VERI::TOUCH::Rev_SCR_SW_Rel) == 0) {
    return ;
  }
  setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
  setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::TOUCH::Touch
  概要  VERIパネルの"Touch"ボタンを押した時の処理。PVM_Panelパネルの操作を環境変数を介して実施しします。
        Touchボタンの左側のテキストボックスで指定されたX,Y座標を使って、シグナル送信します。
        Touchボタンを押下した時に押したシグナルを送信、離した時に離したシグナルを送信します
******************************************************************************************/
on sysvar sysvar::VERI::TOUCH::Touch {
  if (sysGetVariableInt(sysvar::VERI::TOUCH::Touch) == 0) {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
    return ;
  } else {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,sysGetVariableInt(sysvar::VERI::TOUCH::PosX));
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,sysGetVariableInt(sysvar::VERI::TOUCH::PosY));
  }
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::GaibuRun
  概要  VERIパネルの"外部コマンド実行"ボタンを押した時の処理。
        外部コマンド実行の左側のファイル選択にて選択されたコマンドを実行します。
******************************************************************************************/
on sysvar sysvar::VERI::GaibuRun {
  if (sysGetVariableInt(sysvar::VERI::GaibuRun) == 0) {
    return ;
  } else {
    sysGetVariableString(sysvar::VERI::GaibuCommand,InputGaibuFile,elCount(InputGaibuFile));
    sysExec(InputGaibuFile ,"");
  }
  return;
}

//--------------------------------------------------------------------------------
// 関数SoftCameraSW()   
//    対象変数：　signal DSBus::CGW_D::AVN1S73::SW_PVM
//    動作 signal SW_PVMをONにして、100ms後にOFFにする。
//    戻り値：なし
//    引数：なし
//--------------------------------------------------------------------------------
void SoftCameraSW() {
  setSignal(G2M1::BDL::ZN11S26::HSW_PVM, 1); // 既存の状態にかかわらず１にする。
  setTimer(msSW_PVM,100);                       // 100msあとにシグナルを0にする。
  write ("◆%f◆PVMスイッチON",timeNow()/100000.0);
}

//--------------------------------------------------------------------------------
// タイマーイベントハンドラ msSW_PVM   
//    関数SoftCameraSW()でONにしたシグナルSW_PVMを、タイマーカウントアップ後に0にする
//--------------------------------------------------------------------------------
on timer msSW_PVM { // SW_PVMをOFFにする
  cancelTimer (msSW_PVM);
  setsignal(G2M1::BDL::ZN11S26::HSW_PVM,0);
  write ("◆%f◆PVMスイッチOFF",timeNow()/100000.0);
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::CameraSoftSW
  概要  VERIパネルでのカメラSWボタンが押下された時に、SoftCameraSW()を呼び出すことで、0.1秒だけソフトカメラSWをONにする。
******************************************************************************************/
on sysvar sysvar::VERI::CameraSoftSW {    // VERIパネルの「カメラソフトSW」ボタンに対応
  if (sysGetVariableInt(sysvar::VERI::CameraSoftSW) == 0) {
    return ;
  }else{
    SoftCameraSW();
  }
}

/*****************************************************************************************
 関数 SoftCameraSW_Script()  (ソフトカメラスイッチ (スクリプトからの呼び出し用）)
    動作 下記のsignal SW_PVMを1にして、100ms後に0にする。
    対象パネル： PVM_Panel
    対象コントロール：カメラソフトSW押下情報
    対象変数：　signal DSBus::CGW_D::AVN1S73::SW_PVM
******************************************************************************************/
void SoftCameraSW_Script() { // スクリプトから呼び出された時用の関数 設定秒数の間、スクリプト実行を止める
  setSignal(G2M1::BDL::ZN11S26::HSW_PVM, 1); // 既存の状態にかかわらず１にする
  setTimer(msSW_PVM_from_SCRIPT,100);                       // 100msあとにシグナルを0にする。
  write("CAMERA_ON at SoftCameraSW_SCript");
}

/*****************************************************************************************
 タイマーイベントハンドラ msSW_PVM_from_SCRIPT   
    関数SoftCameraSW_Script()でONにしたシグナルSW_PVMを、タイマーカウントアップ後に0にする
******************************************************************************************/
on timer msSW_PVM_from_SCRIPT {
  cancelTimer (msSW_PVM_from_SCRIPT);
  setsignal(G2M1::BDL::ZN11S26::HSW_PVM,0);
  setTimer(msExecInterval, CommandInterval);
  alive_msExecInterval = 1;
  write("CAMERA_OFF and msExecInterval set at SoftCameraSW_SCript");
  
}
/*****************************************************************************************
 工場調整　
--------------------------------------------------------------------------------
 システム変数イベントハンドラ VERI::MICO04   
    動作：VERIパネルの工場調整ボタンが押された時に呼ばれるハンドラ
          ボタンの下にステータスを表すラジオボタンが15個並んでおり、これをクリアする。
          工場調整は、15のステップから構成され、グローバル変数FactoryAdjustStepにてどのステップにいるかを示す
          関数FactoryAdjust()にて、工場調整を実行する。
******************************************************************************************/
on sysvar sysvar::VERI::MICO4 {  // 工場調整用のビューデータ補正の前準備
  if ((sysGetVariableInt(sysvar::VERI::MICO4) == 0 ) && (FactoryAdjustStep != 0) ){
    return ;
  } else {
    sysSetVariableInt(sysvar::VERI::Factory::S01,0);
    sysSetVariableInt(sysvar::VERI::Factory::S02,0);
    sysSetVariableInt(sysvar::VERI::Factory::S03,0);
    sysSetVariableInt(sysvar::VERI::Factory::S04,0);
    sysSetVariableInt(sysvar::VERI::Factory::S05,0);
    sysSetVariableInt(sysvar::VERI::Factory::S06,0);
    sysSetVariableInt(sysvar::VERI::Factory::S07,0);
    sysSetVariableInt(sysvar::VERI::Factory::S08,0);
    sysSetVariableInt(sysvar::VERI::Factory::S09,0);
    sysSetVariableInt(sysvar::VERI::Factory::S10,0);
    sysSetVariableInt(sysvar::VERI::Factory::S11,0);
    sysSetVariableInt(sysvar::VERI::Factory::S12,0);
    sysSetVariableInt(sysvar::VERI::Factory::S13,0);
    sysSetVariableInt(sysvar::VERI::Factory::S14,0);
    sysSetVariableInt(sysvar::VERI::Factory::S15,0);
    FactoryAdjustStep = 0;
    FactoryAdjust();   
    return ;
  }
}

/*****************************************************************************************
 タイマーイベントハンドラ myFactoryRespTimer
    動作：FactoryAdjust()関数の中で、SID10_ADUパネル、SID2E_PVM、SID3E_ADUパネルの中の送信ボタンが押された場合のボタンを離す処理
         （実際に押すのではなく、送信ボタンを押すと、割り当てられているシステム変数が1にセットされるので、
          このハンドラが呼び出されたタイミングで、割り当てられたシステム変数を0にすることでボタンを離した時の動作をさせる 
******************************************************************************************/
on timer msFactoryRespTimer { // 工場調整関係の送信ボタンを離す 
  putValue(EnvSID3E_Tx_ADU,0); 
  putValue(EnvSID3E_Stop_ADU,0);
  putValue(EnvSID10_Tx_ADU,0);
  putValue(EnvSID2E_Tx_PVM,0);

  cancelTimer(msFactoryRespTimer) ;
  write("送信");
}

/*****************************************************************************************
// 環境変数イベントハンドラ EnvSID3E_Resp_Flag_ADU
//    動作：SID3E_ADUパネルの中の肯定応答、否定応答に割り当てられている環境変数EnvSID3E_Resp_Flag_ADUが変化した場合のイベントハンドラ
//          SID3E_ADUにて送信ボタンを押し、レスポンスを受信したときに、レスポンスの種類に応じて、この環境変数の値が変わる（SID3E_ADUパネル上のラジオボタン(肯定／否定）に表示）
//          この環境変数に、126（肯定）または、127（否定）が受信されることで、SID3E_ADUのコマンドレスポンスが得られたことになるので、
//          工場調整の次のステップに進む（FactoryAdjust()関数を呼び出す）
******************************************************************************************/
on envVar EnvSID3E_Resp_Flag_ADU {
  write("SID3E_Resp_Flag: %d (FactoryAdjustStep %d) ", getValue(EnvSID3E_Resp_Flag_ADU) ,FactoryAdjustStep);
  if (FactoryAdjustStep == 1) {
    if ((getValue(EnvSID3E_Resp_Flag_ADU) == 126)/*肯定*/ || (getValue(EnvSID3E_Resp_Flag_ADU) == 127)/*否定*/) {
      FactoryAdjust(); // 肯定でも否定でもいったん進む
      return;
    }
  }
// 　工場調整にてSID3Eの送信停止をやめた（志土地さんアドバイス)
//  if (FactoryAdjustStep == 15) { // SID3E_ADU 通信停止ボタンを押しても肯定も否定も帰ってこず０になる。
//    if (getValue(EnvSID3E_Resp_Flag_ADU) == 0) {
//      FactoryAdjust(); // 肯定でも否定でもいったん進む
//      return;
//    }
//  }
//  write("ここには来ない");  // 最初のステップか最後のステップでなければ何もしない
}

/*****************************************************************************************
// 環境変数イベントハンドラ EnvSID10_Resp_Flag_ADU
//    動作：SID10_ADUパネルの中の肯定応答、否定応答に割り当てられている環境変数EnvSID10_Resp_Flag_ADUが変化した場合のイベントハンドラ
//          SID10_ADUにて送信ボタンを押し、レスポンスを受信したときに、レスポンスの種類に応じて、この環境変数の値が変わる（SID10_ADUパネル上のラジオボタン(肯定／否定）に表示）
//          この環境変数に、80（肯定）または、127（否定）が受信されることで、SID3E_ADUのコマンドレスポンスが得られたことになるので、
//          工場調整の次のステップに進む（FactoryAdjust()関数を呼び出す）
******************************************************************************************/
on envVar EnvSID10_Resp_Flag_ADU {
  write("SID10_Resp_Flag: %d ", getValue(EnvSID10_Resp_Flag_ADU));
  if ((getValue(EnvSID10_Resp_Flag_ADU) == 80)/*肯定*/ || (getValue(EnvSID3E_Resp_Flag_ADU) == 127)/*否定*/) {
      FactoryAdjust(); // 肯定でも否定でもいったん進む
  }
}

/*****************************************************************************************
// 環境変数イベントハンドラ EnvSID2E_Resp_Flag_PVM
//    動作：SID2E_PVMパネルの中の肯定応答、否定応答に割り当てられている環境変数EnvSID2E_Resp_Flag_PVMが変化した場合のイベントハンドラ
//          SID2E_ADUにて送信ボタンを押し、レスポンスを受信したときに、レスポンスの種類に応じて、この環境変数の値が変わる（SID2E_ADUパネル上のラジオボタン(肯定／否定）に表示）
//          この環境変数に、110（肯定）または、127（否定）が受信されることで、SID2E_PVMのコマンドレスポンスが得られたことになるので、
//          工場調整の次のステップに進む（FactoryAdjust()関数を呼び出す）
******************************************************************************************/
on envVar EnvSID2E_Resp_Flag_PVM {
  write("EnvSID2E_Resp_Flag_PVM %d", getValue(EnvSID2E_Resp_Flag_PVM));
  if ((getValue(EnvSID2E_Resp_Flag_PVM) == 110)/*肯定*/) { // || (getvalue(EnvSID2E_Resp_Flag_PVM) == 127)/*否定*/) {
      FactoryAdjust(); //　肯定の時に次へ進む
  }
}
//動作確認用
on envVar EnvSID10_ID_ADU {
  write("EnvSID10_ID_ADU %d", getValue(EnvSID10_ID_ADU));
}

//動作確認用
on envVar EnvSID2E_DID_Tx_PVM {
  write("EnvSID2E_DID_Tx_PVM %x", getValue(EnvSID2E_DID_Tx_PVM));
}

//動作確認用
on envVar EnvSID2E_id5148_pos26_Tx_PVM {
  write("EnvSID2E_id5148_pos26_Tx_PVM %d", getValue(EnvSID2E_id5148_pos26_Tx_PVM));
}

/*****************************************************************************************
// 関数 FactoryAdjust()  SID2E_PVMパネルで行う、工場調整の設定を行う
//    説明 関係するコマンドの受信ごとにこの関数が呼ばれる。
//      グローバル変数 FactoryAdjustStep によって、FactoryAdjustStep()関数の動作が変わる
//       FactoryAdjustStep   :   動作
//           0               :   SID3E_ADUパネルにて送信ボタンを押す。 FactoryAdjustStepを1に進めて、関数を抜ける
//                               これのレスポンスを判定するEnvSID3E_Resp_Flag_ADUのイベントハンドラから再度この関数が呼ばれることで、
//                               次のステップである 1 の処理が実行される
//           1               :   SID10_ADUパネルで、$01デフォルトを選択して送信ボタンを押す。FactoryAdjustStepを2に進めて関数を抜ける
//                               これのレスポンスを判定するEnvSID10_Resp_Flag_ADUのイベントハンドラから再度この関数が呼ばれることで、
//                               次のステップである 2 の処理が実行される
//           2               :   SID10_ADUパネルで、$03拡張を選択して、送信ボタンを押す。FactorAdjustStepを3に進めて関数を抜ける
//                               これのレスポンスを判定するEnvSID10_Resp_Flag_ADUのイベントハンドラから再度この関数が呼ばれることで、
//                               次のステップである 3 の処理が実行される
//           3               :   SID2E_PVMパネルで、$5140 光軸調整乗員書き込みを送信する。FactoryAdjstStepを4にしておき、レスポンスがきたら、次ステップ4に進む
//           4               :   SID2E_PVMパネルで、$5141 光軸調整判定閾値   を送信する。FactoryAdjstStepを5にしておき、レスポンスがきたら、次ステップ5に進む
//           5               :   SID2E_PVMパネルで、$5142 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置(後方)を送信する。FactoryAdjstStepを6にしておき、レスポンスがきたら、次ステップ6に進む
//           6               :   SID2E_PVMパネルで、$5143 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置(前方)を送信する。FactoryAdjstStepを7にしておき、レスポンスがきたら、次ステップ7に進む
//           7               :   SID2E_PVMパネルで、$5144 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_バックカメラ正面マーカー(向き)を送信する。FactoryAdjstStepを8にしておき、レスポンスがきたら、次ステップ8に進む
//           8               :   SID2E_PVMパネルで、$5145 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_バックカメラ正面マーカーを送信する。FactoryAdjstStepを9にしておき、レスポンスがきたら、次ステップ9に進む
//           9               :   SID2E_PVMパネルで、$5146 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_フロントカメラ正面マーカー(向き)を送信する。FactoryAdjstStepを10にしておき、レスポンスがきたら、次ステップ10に進む
//           10              :   SID2E_PVMパネルで、$5147 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_フロントカメラ正面マーカーを送信する。FactoryAdjstStepを11にしておき、レスポンスがきたら、次ステップ11に進む
//           11              :   SID2E_PVMパネルで、$5148 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_サイドカメラ正面マーカー(向き)光軸調整乗員書き込みを送信する。FactoryAdjstStepを12にしておき、レスポンスがきたら、次ステップ12に進む
//           12              :   SID2E_PVMパネルで、$5149 自動光軸ﾀｰｹﾞｯﾄﾏｰｶｰ位置_サイドカメラ正面マーカー光軸調整乗員書き込みを送信する。FactoryAdjstStepを13にしておき、レスポンスがきたら、次ステップ13に進む
//           13              :   SID10_ADUパネルで、$01デフォルトを選択して送信ボタンを押す。FactoryAdjustStep15にしておき、レスポンスが来たら、次ステップ15へ進む
//           14              :   SID3E_ADUパネルで、送信停止を送信する（不要とのことなので欠番）
//           15              :   スクリプトの次の行を実行するたえに、スクリプト実行タイマー msExecIntervalをセットする。次はタイマーハンドラmsExecIntervalにて、次の行を実施する
******************************************************************************************/
void FactoryAdjust() { //工場調整
  write ("FactotyAdjStep: %d", FactoryAdjustStep ) ;
  if (FactoryAdjustStep == 0) {
    // 1: SID3E_ADU $00 送信
    putValue(EnvSID3E_RspNecessity_ADU,0);
    putValue(EnvSID3E_Tx_ADU,1); // 送信ボタンを押す
    setTimer(msFactoryRespTimer,1); // 1ms後にボタンを離す    
    FactoryAdjustStep = 1;
//    return;
  } else if (FactoryAdjustStep == 1) {
    sysSetVariableInt(sysvar::VERI::Factory::S01,1);  // １つめ完了　２つ目へ
      // 2: SID10_ADU $01:デフォルト
    putValue(EnvSID10_ID_ADU, 1); // $01:デフォルト
    putValue(EnvSID10_RspNecessity_ADU, 0); // アクティブレスポンス要
    putValue(EnvSID10_Tx_ADU,1); // 送信ボタンを押す
    setTimer(msFactoryRespTimer,1); // 1ms後にボタン離す
    FactoryAdjustStep = 2;
  } else if (FactoryAdjustStep == 2) {
    sysSetVariableInt(sysvar::VERI::Factory::S02,1); //２つめ完了３つめへ進む
      // 3: SID10_ADU $03:拡張
    putValue(EnvSID10_ID_ADU, 3); //$03:拡張
    putValue(EnvSID10_RspNecessity_ADU, 0); //アクティブレスポンス要
    putValue(EnvSID10_Tx_ADU,1); //　送信ボタン押す
    setTimer(msFactoryRespTimer,1); // 1ms後にボタン離す
    FactoryAdjustStep = 3;
  } else if (FactoryAdjustStep == 3) {
    sysSetVariableInt(sysvar::VERI::Factory::S03,1); // ３つ目完了
      // 4: SID2E_PVM $5140:光軸調整乗員書き込み   01
    putValue(EnvSID2E_DID_Tx_PVM,0x5140); // 
    putValue(EnvSID2E_id5140_pos10_Tx_PVM,1) ;
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,10);
    FactoryAdjustStep = 4;
  } else if (FactoryAdjustStep == 4) {
    sysSetVariableInt(sysvar::VERI::Factory::S04,1);
      // 5: SID2E_PVM $5141:光軸調整検査判定... 　    // Automationの手順では送っていないが、MICOの手順書では送っている
    putValue(EnvSID2E_DID_Tx_PVM,0x5141);
    putValue(EnvSID2E_id5141_pos10_Tx_PVM,0x0);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,10);
    FactoryAdjustStep = 5;
  } else if (FactoryAdjustStep == 5) {
    sysSetVariableInt(sysvar::VERI::Factory::S05,1);
      // 6: SID2E_PVM $5142:自動光軸ターゲットマーカー位置(後方)_PVM  
    putValue(EnvSID2E_DID_Tx_PVM,0x5142);
    putValue(EnvSID2E_id5142_pos20_Tx_PVM,4850);
    putValue(EnvSID2E_id5142_pos40_Tx_PVM,1400);
    putValue(EnvSID2E_id5142_pos60_Tx_PVM,220);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 6;
  } else if (FactoryAdjustStep == 6) {
    sysSetVariableInt(sysvar::VERI::Factory::S06,1);
      // 7: SID2E_PVM $5143:自動光軸ターゲットマーカー位置　1500、1400、220
    putValue(EnvSID2E_DID_Tx_PVM,0x5143);
    putValue(EnvSID2E_id5143_pos20_Tx_PVM,1500);
    putValue(EnvSID2E_id5143_pos40_Tx_PVM,1400);
    putValue(EnvSID2E_id5143_pos60_Tx_PVM,220);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 7;
  } else if (FactoryAdjustStep == 7) {
    sysSetVariableInt(sysvar::VERI::Factory::S07,1);
      // 8: SID2E_PVM $5144:自動光軸ターゲットマーカー　　　0040  ターゲットマーカーH方向のみ"1", 他は"0"
    putValue(EnvSID2E_DID_Tx_PVM,0x5144);
    putValue(EnvSID2E_id5144_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 8;
  } else if (FactoryAdjustStep == 8) {
    sysSetVariableInt(sysvar::VERI::Factory::S08,1);
      // 9: SID2E_PVM $5145:自動光軸ターゲットマーカー　　　5600、0、50
    putValue(EnvSID2E_DID_Tx_PVM,0x5145);
    putValue(EnvSID2E_id5145_pos20_Tx_PVM,5600);
    putvalue(EnvSID2E_id5145_pos40_Tx_PVM,0);
    putvalue(EnvSID2E_id5145_pos60_Tx_PVM,50);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 9;
  } else if (FactoryAdjustStep == 9) {
    sysSetVariableInt(sysvar::VERI::Factory::S09,1);
      //10: SID2E_PVM $5146:自動光軸ターゲットマーカー　　　0040　ターゲットマーカーH方向のみ"1", 他は"0"
    putValue(EnvSID2E_DID_Tx_PVM,0x5146);
    putValue(EnvSID2E_id5146_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 10;
  } else if (FactoryAdjustStep == 10) {
    sysSetVariableInt(sysvar::VERI::Factory::S10,1);
      //11: SID2E_PVM $5147:自動光軸ターゲットマーカー　　　2260、0、50
    putvalue(EnvSID2E_DID_Tx_PVM,0x5147);
    putvalue(EnvSID2E_id5147_pos20_Tx_PVM,2260);
    putvalue(EnvSID2E_id5147_pos40_Tx_PVM,0);
    putvalue(EnvSID2E_id5147_pos60_Tx_PVM,50);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 11;    
  } else if (FactoryAdjustStep == 11) {
    sysSetVariableInt(sysvar::VERI::Factory::S11,1);
      //12: SID2E_PVM $5148:自動光軸ターゲットマーカー　　　0040  ターゲットマーカーH方向のみ"1!, 他は"0"
    putvalue(EnvSID2E_DID_Tx_PVM,0x5148);
    putValue(EnvSID2E_id5148_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 12;
  } else if (FactoryAdjustStep == 12) {
    sysSetVariableInt(sysvar::VERI::Factory::S12,1);
    //13: SID2E_PVM $5149:自動光軸ターゲットマーカー　　　0,1450,700
    putValue(EnvSID2E_DID_Tx_PVM,0x5149);
    putvalue(EnvSID2E_id5149_pos20_Tx_PVM,0);
    putvalue(EnvSID2E_id5149_pos40_Tx_PVM,1450);
    putvalue(EnvSID2E_id5149_pos60_Tx_PVM,700);
    putValue(EnvSID2E_Tx_PVM,1);  // 送信ボタン押す
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 13;
  } else if (FactoryAdjustStep == 13) {
    sysSetVariableInt(sysvar::VERI::Factory::S13,1);
    //14: SID10_ADU $01:デフォルト
    putValue(EnvSID10_ID_ADU, 1); // $01:デフォルト
    putValue(EnvSID10_RspNecessity_ADU, 0); // アクティブレスポンス要
    putValue(EnvSID10_Tx_ADU,1); // 送信ボタンを押す
    setTimer(msFactoryRespTimer,1); // 1ms後にボタン離す
    FactoryAdjustStep = 15;    // Step14を飛ばす
  } else if (FactoryAdjustStep == 14) {
    sysSetVariableInt(sysvar::VERI::Factory::S14,1);
    //15: SID3E_ADU $00 送信停止
    // このコマンドは応答が帰ってこないように見える。250805 志土地さんに確認したところ不要ではないかとのことで削除
//    putValue(EnvSID3E_Resp_Flag_ADU,0);
//    putValue(EnvSID3E_RspNecessity_ADU,0);
//    putValue(EnvSID3E_Stop_ADU,1); // 送信ボタンを押す
//    setTimer(msFactoryRespTimer,1); // 1ms後にボタンを離す        
//    FactoryAdjustStep = 15;
  } else if (FactoryAdjustStep == 15) {
    sysSetVariableInt(sysvar::VERI::Factory::S15,1);
    setTimer(msExecInterval,CommandInterval);
    alive_msExecInterval = 1;
  } else {
    write("ここには来ない　at factoryadjust()");
  }
}
  
/*****************************************************************************************
// ダイアグ 1483送信
//--------------------------------------------------------------------------------
// 関数 outputExtMsg1483()  
//    引数なし
//    戻り値なし
//  動作：ダイアグ 1483送信
//    受信の5バイト目が、ビューデータ生成の状態を表す 0x05になったら完了
//    拡張ID：0x18DA75E0
//    DLC : 8バイト
//    送信データ：0x03, 0x22, 0x14, 0x83, 0x00, 0x00, 0x00, 0x00(後ろの４つは意味なし）
//    受信データ：0x04, 0x62, 0x14, 0x83, 0xXX, 0x00, 0x00, 0x00(後ろの３つは意味なし）
//        data(5)の0xXXがビューデータ生成の状態
//    対象変数：　signal DSBus::CGW_D::AVN1S73::SW_PVM
//    動作 ダイアグ1483を送信する
//    条件 いつでも送信可能
******************************************************************************************/
void outputExtMsg1483() {
  ExtMsg1483.id = mkExtID(0x18DA75E0);
  ExtMsg1483.dlc=8;
  ExtMsg1483.byte(0) = 0x03;
  ExtMsg1483.byte(1) = 0x22;
  ExtMsg1483.byte(2) = 0x14;
  ExtMsg1483.byte(3) = 0x83;
  output(ExtMsg1483);
}

/*****************************************************************************************
// ダイアグ 1483送信
// VERI パネルから、Msg1483ボタンを押した時の動作
******************************************************************************************/
on sysvar sysvar::VERI::Msg1483 {
  if (sysGetVariableInt(sysvar::VERI::Msg1483) == 0) {
    return;
  } else {
    outputExtMsg1483();
    write("Send 1483"); 
    sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 0);  //表示消し
    sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 0); // 表示消し
  }
}

/*****************************************************************************************
// ダイアグ1483のレスポンスの受信 (スクリプトからの1483と、パネルからの1483の両方に対応
// 拡張IDのためか、DIDのみ選択して受信することができないため、全部受信してIDを比較して受信することにした
******************************************************************************************/
on message * {
//  write("%X", this.id);
  if (this.id == mkExtId(0x18DAE075)) {
    // msg 1483処理ーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーー
    if ((this.byte(2)==0x14) && (this.byte(3)==0x83)) { 
//    write("Receive 1483 %02X %02X %02X %02X %02X %02X %02X %02X",this.byte(0),this.byte(1),this.byte(2),this.byte(3),this.byte(4),this.byte(5),this.byte(6),this.byte(7));
    write("Receive 1483 %02X",this.byte(4));
      if (this.byte(4) == 5) {
        sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 1);
        sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 0);
      } else {
        sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 1);
        sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 0);
      }
      
      sysSetVariableInt(sysvar::VERI::Msg1483_retval, this.byte(4));
    
    
      if (isMsg1483FromScript == 1) {// スクリプトからの呼び出し
        if (this.byte(4) == 5) {  //戻り値が５の場合、通常の実行に戻る
          cancelTimer(msMsg1483Retry); //リトライタイマーのキャンセル    
                                     //スクリプト実行再開
          setTimer(msExecInterval,CommandInterval);
          alive_msExecInterval = 1;
                                    //呼び出し元を示す変数を戻す（これをしないと、パネルからの呼び出しでリトライしてしまう）
          isMsg1483FromScript = 0;
        } else {                  //戻り値が５以外の場合リトライする
        //リトライタイマーのセット
          setTimer(msMsg1483Retry, 500) ;
        } 
      }else { // スクリプトからではない呼び出し（パネルボタン）
        }
      }
    // msg DID処理ーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーーー    
    // パネル呼び出しによるDID取得
    //-------13A0---------
//    write("this.byte(2)%02X,this.byte(3)%02X",this.byte(2),this.byte(3));
    if ((waitA0 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA0)) {
      ret_BackNum = this.byte(4);
      write("LastBackView: %02X",ret_BackNum);
      sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,ret_BackNum);
      updateLastBackViewText(ret_BackNum);
      waitA0 = 0;
    }
    //-------13A1---------
    if ((waitA1 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA1)) {
      ret_FrontNum = this.byte(4);
      write("LastFrontView: %02X",ret_FrontNum);
      sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,ret_FrontNum);
      updateLastFrontViewText(ret_FrontNum);
      waitA1 = 0;
    }
    //-------13A3---------
    if ((waitA3 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA3)) {
      ret_AutoDisp = this.byte(4);
      write("LastAutoDisp: %02X",ret_AutoDisp);
      sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,ret_AutoDisp);
      updateAutoDispMode(ret_AutoDisp);
      waitA3 = 0;
    }
    //-------13A4------------
    if ((waitA4 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA4)) {
      ret_AutoCamera = this.byte(4);
      write("LastAutoCamera: %02X",ret_AutoCamera);
      sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,ret_AutoCamera);
      updateCameraViewAutoOff(ret_AutoCamera);
      waitA4 = 0;
    }
    
    //コマンドからの呼び出しによるDID取得
    if(initViewActive == 1)
    {
      //-------13A0------------
    if ((this.byte(2)==0x13)&&(this.byte(3)==0xA0)) {
        ret_BackNum = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,ret_BackNum);
        updateLastBackViewText(ret_BackNum);
        didlow = 0xA1;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A0");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA1)) {
      //-------13A1-------------
        ret_FrontNum = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,ret_FrontNum);
        updateLastFrontViewText(ret_FrontNum);
        didlow = 0xA3;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A1");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA3)) {
      //--------13A3-------------
        ret_AutoDisp = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,ret_AutoDisp);
        updateAutoDispMode(ret_AutoDisp);
        didlow = 0xA4;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A3");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA4)) {
      //--------13A4--------------
        ret_AutoCamera = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,ret_AutoCamera);
        updateCameraViewAutoOff(ret_AutoCamera);
        sysSetVariableInt(sysvar::VERI::DID::didReceived,1);
        write("INIT_VIEW : send DID 13A4");
        return;
      }
    }
  }
}

/*****************************************************************************************
//DID取得用のタイマー
*****************************************************************************************/
on timer sendDID{
  write("DID送信");
  if ((didlow == 0xA0) || (didlow == 0xA1) || (didlow == 0xA3) || (didlow == 0xA4)){
    outputDiagReq(didlow);
  }
  cancelTimer(sendDID);
}

/*****************************************************************************************
 ダイアグ1483のリトライタイマー　
--------------------------------------------------------------------------------
 タイマーイベントハンドラ msMsg1483Retry   
    動作：タイムアップにて、ダイアグ1483を再送する
******************************************************************************************/
on timer msMsg1483Retry {  // 1483のリトライタイマー
  cancelTimer(msMsg1483Retry);
  outputExtMsg1483();
}

/*
on sysvar sysvar::VERI::TouchPanelAvailable {
  if (sysGetVariableInt(sysvar::VERI::TouchPanelAvailable) == 0) {
    // タッチパネル無効
    cancelTimer(
  } else {
    // タッチパネル有効
  }
}
*/
