    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"T127D",strlen(scrCommand))==0) { //ターゲットマーカ強制
    putValue(EnvSID31_RID_Tx_PVM, 0x127D);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"T1240",strlen(scrCommand))==0) { //$1240：ターゲットマーカ認識開始要求
    putValue(EnvSID31_RID_Tx_PVM, 0x1240);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"T1247",strlen(scrCommand))==0) { //$1247：光軸調整検査画面表示要求(画面レス)_PVM
    putValue(EnvSID31_RID_Tx_PVM, 0x1247);
    putValue(EnvSID31_Type_PVM,1);  // StartRoutine 
    putValue(EnvSID31_RspNecessity_PVM,0); // アクティブレスポンス要
    putValue(EnvSID31_Tx_PVM,1);  // 送信
    cancelTimer(msExecInterval);  // 次のコマンドへは進まない
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"V1241",strlen(scrCommand))==0) { //$1241：ビューデータ開始要求
    putValue(EnvSID31_RID_Tx_PVM, 0x1241);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  
  if (strncmp(scrCommand,"LANGUAGE",strlen(scrCommand))==0) {//AVN1S20(434)言語設定
