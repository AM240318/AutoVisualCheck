/******************************************************************************************
//initview() 弶婜壔娭悢
******************************************************************************************/
 void initview(){
  //DID傪巊偭偰尰嵼抣傪庢摼偡傞
  didlow = 0xA0; // DID偺斣崋
  setTimer(sendDID,20);

}

/******************************************************************************************
//DID庢摼姰椆屻
//弶婜抣偐偳偆偐敾抐偟丄InitViewSeq僞僀儅乕傪巊偭偰丄弶婜壔偡傞
//initTargetView 0:儔僗僩僶僢僋價儏乕 1:儔僗僩僼儘儞僩價儏乕 2:帺摦昞帵儌乕僪 3:僇儊儔塮憸帺摦
******************************************************************************************/
on sysvar sysvar::VERI::DID::didReceived {
  if (sysGetVariableInt(sysvar::VERI::DID::didReceived) == 0) {
    return;
  } else {
    initTargetView = 0; //弶婜壔僞乕僎僢僩傪0:儔僗僩僶僢僋價儏乕偐傜巒傔傞
    initViewStep = 1;
    write("弶婜壔奐巒");

    setTimer(InitViewSeq,initTargetViewInterval);
    sysSetVariableInt(sysvar::VERI::DID::didReceived,0) ;
  }
}

/******************************************************************************************
// 儔僗僩夋弶婜壔偺張棟傪峴偆
//initTargetView 0:儔僗僩僶僢僋價儏乕 1:儔僗僩僼儘儞僩價儏乕 2:帺摦昞帵儌乕僪 3:僇儊儔塮憸帺摦
*******************************************************************************************/
on timer InitViewSeq{
  
  cancelTimer(InitViewSeq);  
  
  if(initTargetView == 0){//丂儔僗僩僶僢僋價儏乕偺弶婜壔張棟
    if(ret_BackNum == 1) {               //儔僗僩僶僢僋價儏乕偺栠傝抣偑侾丗儚僀僪僶僢僋價儏乕偺応崌丅
//      write("LastBackView:儚僀僪僶僢僋價儏乕");
      switch(initViewStep){
        case 1:                                       // 儕僶乕僗偵擖傟傞
          write("1:儕僶乕僗偵擖傟傞");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                      // 儈儔乕傪奐偔
          write("儈儔乕傪奐偔");
          setSignal(G2M1::BDL::BDB1S04::MRMV_R,0) ;
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                      // 幵懍傪0km偵偡傞
          write("幵懍傪0km偵偡傞");
          setSignal(G2M1::DDM21::VSC1G13::SP1,0);
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // 夋柺愗傝懼偊儃僞儞傪墴壓偡傞
          write("夋柺愗傝懼偊儃僞儞傪墴壓偡傞");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                      // 夋柺愗傝懼偊儃僞儞傪棧偡
          write("夋柺愗傝懼偊儃僞儞傪棧偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                     // 僷乕僉儞僌偵栠偡
          write("僷乕僉儞僌偵栠偡");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 1;                           // 師偼1丗儔僗僩僼儘儞僩價儏乕偺張棟
          initViewStep = 1;                               // 僇僂儞僞傪侾偵
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID弶婜壔僄儔乕0");
          return;
      }
    } else {                   //儔僗僩僶僢僋價儏乕偺栠傝抣偑0丗僫儘乕僶僢僋價儏乕偺応崌丅
      write("尦偐傜僫儘乕僶僢僋價儏乕");
      initTargetView = 1;                               // 壗傕偣偢偵丄1:儔僗僩僼儘儞僩價儏乕偺張棟偵恑傓
      initViewStep = 1; 
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 1) { // 儔僗僩僼儘儞僩價儏乕偺弶婜壔張棟
    if (ret_FrontNum == 1) {                  // 儔僗僩僼儘儞僩價儏乕偺栠傝抣偑1: 僒僀僪僋儕傾儔儞僗價儏乕偺応崌丅
      switch(initViewStep) {
        case 1:                                         // 僪儔僀僽偵擖傟傞
          write("僪儔僀僽偵擖傟傞");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                        // 儈儔乕奐偔
          write("儈儔乕奐偔");
          setSignal(G2M1::BDL::BDB1S04::MRMV_R,0) ;
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                      // 幵懍傪0km偵偡傞
          write("幵懍傪0km偵偡傞");
          setSignal(G2M1::DDM21::VSC1G13::SP1,0);
          if (ret_AutoDisp == 1) {  // AutoDisp偑1:ON偺応崌丄PVM偑昞帵偝傟偰偄傞偨傔丄僇儊儔僗僀僢僠傪墴偝側偄丂儔僗僩夋偑昞帵偝傟傞乮僒僀僪僼儘儞僩價儏乕乯
            initViewStep = 8;       // 夋柺愗懼儃僞儞傪侾夞墴偡丂乮儚僀僪僼儘儞僩價儏乕乯乮儔僗僩夋峏怴乯
          } else {                  // AutoDisp偑1偱側偄応崌丄PVM偑昞帵偝傟偰偄側偄偨傔丄僇儊儔僗僀僢僠傪墴偡丂丂儚僀僪僼儘儞僩價儏乕偑昞帵偝傟傞丅乮屌掕乯
            initViewStep = 4;       // 僇儊儔僗僀僢僠傪墴偡乮儚僀僪僼儘儞僩乯仺丂夋柺愗懼墴壓侾夞栚乮僒僀僪僼儘儞僩價儏乕昞帵乯丂仺丂夋柺愗懼墴壓俀夞栚乮儚僀僪僼儘儞僩價儏乕乯乮偙傟偱儔僗僩夋偑峏怴乯
          }
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // 僇儊儔僗僀僢僠傪墴偡  (TSS4偲BEV偱偼摦偒偑堘偆偺偱拲堄)
          write(" 僇儊儔僗僀僢僠傪墴偡 ");
          setSignal(G2M1::CDC21::AVN1S73::SW_PVM, 1); // 婛懚偺忬懺偵偐偐傢傜偢1偵偡傞
          //          sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,1);
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                      // 僇儊儔僗僀僢僠傪棧偡  (TSS4偲BEV偱偼摦偒偑堘偆偺偱拲堄)
          write("僇儊儔僗僀僢僠傪棧偡");
          setSignal(G2M1::CDC21::AVN1S73::SW_PVM, 0); // 婛懚偺忬懺偵偐偐傢傜偢0偵偡傞
          //sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,0);
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                      // 夋柺愗傝懼偊儃僞儞傪墴偡丂丂
          write("夋柺愗傝懼偊儃僞儞傪墴偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 7;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 7:                                      // 夋柺愗傝懼偊儃僞儞傪棧偡
          write("夋柺愗傝懼偊儃僞儞傪棧偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 8;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 8:                                      // 夋柺愗傝懼偊儃僞儞傪墴偡丂丂
          write("夋柺愗傝懼偊儃僞儞傪墴偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 9;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 9:                                      // 夋柺愗傝懼偊儃僞儞傪棧偡
          write("夋柺愗傝懼偊儃僞儞傪棧偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 10;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 10:                                      // 僷乕僉儞僌偵栠偡
          write("僷乕僉儞僌偵栠偡");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 2;                        // 師偼2丗帺摦昞帵儌乕僪偺張棟
          initViewStep = 1;                               // 僇僂儞僞傪侾偵
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID弶婜壔僄儔乕1");
          return;
      }
    } else {                                 // 儔僗僩僼儘儞僩價儏乕偺栠傝抣偑0: 儚僀僪僼儘儞僩價儏乕偺応崌
      write("尦偐傜儚僀僪僼儘儞僩價儏乕");
      initTargetView = 2;                               // 壗傕偣偢偵丄2:帺摦昞帵儌乕僪乕偺張棟偵恑傓
      initViewStep = 1; 
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 2) { // 帺摦昞帵儌乕僪偺弶婜壔張棟丂
    if (ret_AutoDisp == 1){             //帺摦昞帵儌乕僪偺栠傝抣偑丂1:ON偺応崌偺弶婜壔張棟
      switch(initViewStep){
        case 1:                                         //僪儔僀僽偵擖傟傞
          write("僪儔僀僽偵擖傟傞");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4);  
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                         //帺摦昞帵儃僞儞傪墴偡
          write("帺摦昞帵儃僞儞傪墴偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,400);
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                         //帺摦昞帵儃僞儞傪棧偡
          write("帺摦昞帵儃僞儞傪棧偡");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // 僷乕僉儞僌偵栠偡
          write("僷乕僉儞僌偵栠偡");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 3;                         // 師偼3: 僇儊儔塮憸帺摦OFF偺張棟
          initViewStep = 1;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID弶婜壔僄儔乕2");
          return;
      }
    } else {                                // 帺摦昞帵儌乕僪偺栠傝抣偑0: OFF偺応崌乮僨僼僅儖僩)
      write("尦偐傜帺摦昞帵儌乕僪OFF");
      initTargetView = 3;                         // 側偵傕偣偢偵丄3:僇儊儔塮憸堏摦僆僼偺愝掕偵恑傓
      initViewStep = 1;
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 3){ // 僇儊儔塮憸帺摦僆僼偺弶婜壔張棟  BEV偱偼傑偭偨偔摦偒偑堘偄偦偆側偺偱妋擣偑昁梫
    if(ret_AutoCamera ==1){           //丂僇儊儔塮憸帺摦僆僼偺栠傝抣偑1:OFF偺応崌偺弶婜壔張棟   
      switch(initViewStep){
        case 1:                                         // CUST_PVM僔僌僫儖傪ON偵偡傞
          write("CUST_PVM僔僌僫儖傪ON偵偡傞");
          setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,1);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                         // CUST_PVM僔僌僫儖傪OFF偵偡傞  愝掕夋柺偵慗堏偡傞   
          write("CUST_PVM僔僌僫儖傪OFF偵偡傞  愝掕夋柺偵慗堏偡傞");
          setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,0);
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                         // 僞僢僠僷僱儖傪墴偡丂乮僇儊儔塮憸帺摦僆僼傪ON偡傞丅乮僨僼僅儖僩抣偵栠偡乯乯
          write("僞僢僠僷僱儖傪墴偡乮僇儊儔塮憸帺摦僆僼傪ON偡傞丅乮僨僼僅儖僩抣偵栠偡乯乯");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,700);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);    
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                         // 僞僢僠僷僱儖傪棧偡丂乮僇儊儔塮憸帺摦僆僼傪ON偵偡傞
          write("僞僢僠僷僱儖傪棧偡乮僇儊儔塮憸帺摦僆僼傪ON偵偡傞");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);    
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                         // 僞僢僠僷僱儖傪墴偡丂丂乮愝掕夋柺傪敳偗傞
          write("僞僢僠僷僱儖傪墴偡乮愝掕夋柺傪敳偗傞");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,160);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,40);    
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                         // 僞僢僠僷僱儖傪棧偡丂乮愝掕夋柺敳偗傞
          write("僞僢僠僷僱儖傪棧偡乮愝掕夋柺敳偗傞");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);   
          initViewStep = 7;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 7:                                         //儕僶乕僗偵擖傟傞乮MM夋柺偵栠傜側偄応崌偑偁傞偨傔乯
          write("儕僶乕僗偵擖傟傞");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
          initViewStep = 8;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 8:                                          //僷乕僉儞僌偵栠偡
          write("僷乕僉儞僌偵栠偡");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initViewStep = 9;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 9:                                         //丂弶婜壔姰椆
          write("弶婜壔姰椆");
          setTimer(msExecInterval,0);                 // 師偺僗僋儕僾僩峴偺幚峴偵旘偽偡 壖偵僐儊儞僩傾僂僩
          alive_msExecInterval = 1;
          //cancelTimer(msExecInterval);
          //alive_msExecInterval = 0;
          initViewActive =0;
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID弶婜壔僄儔乕3 %d",initViewStep);
          return;
      }
    } 
      else {
      write("尦偐傜僇儊儔帺摦儌乕僪ON");
      write("弶婜壔姰椆");
      setTimer(msExecInterval,0);                 // 師偺僗僋儕僾僩峴偺幚峴偵旘偽偡 壖偵僐儊儞僩傾僂僩
      alive_msExecInterval = 1;
      //cancelTimer(msExecInterval);
      //alive_msExecInterval = 0;
      initViewActive =0;
      return;
     }
  } else { // initTargetView 偑0偐傜3偺娫偱側偄応崌
    write("!!! 儔僗僩夋娭楢(DID)弶婜壔僄儔乕");
    return;
  }
}