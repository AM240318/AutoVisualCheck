/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::TOUCH::Touch
  奣梫  VERI僷僱儖偺"Touch"儃僞儞傪墴偟偨帪偺張棟丅PVM_Panel僷僱儖偺憖嶌傪娐嫬曄悢傪夘偟偰幚巤偟偟傑偡丅
        Touch儃僞儞偺嵍懁偺僥僉僗僩儃僢僋僗偱巜掕偝傟偨X,Y嵗昗傪巊偭偰丄僔僌僫儖憲怣偟傑偡丅
        Touch儃僞儞傪墴壓偟偨帪偵墴偟偨僔僌僫儖傪憲怣丄棧偟偨帪偵棧偟偨僔僌僫儖傪憲怣偟傑偡
******************************************************************************************/
on sysvar sysvar::VERI::TOUCH::Touch {
  if (sysGetVariableInt(sysvar::VERI::TOUCH::Touch) == 0) {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
    return ;
  } else {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,sysGetVariableInt(sysvar::VERI::TOUCH::PosX));
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,sysGetVariableInt(sysvar::VERI::TOUCH::PosY));
  }
}
/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::GaibuRun
  奣梫  VERI僷僱儖偺"奜晹僐儅儞僪幚峴"儃僞儞傪墴偟偨帪偺張棟丅
        奜晹僐儅儞僪幚峴偺嵍懁偺僼傽僀儖慖戰偵偰慖戰偝傟偨僐儅儞僪傪幚峴偟傑偡丅
******************************************************************************************/
on sysvar sysvar::VERI::GaibuRun {
  if (sysGetVariableInt(sysvar::VERI::GaibuRun) == 0) {
    return ;
  } else {
    sysGetVariableString(sysvar::VERI::GaibuCommand,InputGaibuFile,elCount(InputGaibuFile));
    sysExec(InputGaibuFile ,"");
  }
  return;
}

//--------------------------------------------------------------------------------
// 娭悢SoftCameraSW()   
//    懳徾曄悢丗丂signal DSBus::CGW_D::AVN1S73::SW_PVM
//    摦嶌 signal SW_PVM傪ON偵偟偰丄100ms屻偵OFF偵偡傞丅
//    栠傝抣丗側偟
//    堷悢丗側偟
//--------------------------------------------------------------------------------
void SoftCameraSW() {
  setSignal(G2M1::BDL::ZN11S26::HSW_PVM, 1); // 婛懚偺忬懺偵偐偐傢傜偢侾偵偡傞丅
  setTimer(msSW_PVM,100);                       // 100ms偁偲偵僔僌僫儖傪0偵偡傞丅
  write ("仧%f仧PVM僗僀僢僠ON",timeNow()/100000.0);
}

//--------------------------------------------------------------------------------
// 僞僀儅乕僀儀儞僩僴儞僪儔 msSW_PVM   
//    娭悢SoftCameraSW()偱ON偵偟偨僔僌僫儖SW_PVM傪丄僞僀儅乕僇僂儞僩傾僢僾屻偵0偵偡傞
//--------------------------------------------------------------------------------
on timer msSW_PVM { // SW_PVM傪OFF偵偡傞
  cancelTimer (msSW_PVM);
  setsignal(G2M1::BDL::ZN11S26::HSW_PVM,0);
  write ("仧%f仧PVM僗僀僢僠OFF",timeNow()/100000.0);
}

/*****************************************************************************************
僔僗僥儉曄悢僀儀儞僩僴儞僪儔  VERI::CameraSoftSW
  奣梫  VERI僷僱儖偱偺僇儊儔SW儃僞儞偑墴壓偝傟偨帪偵丄SoftCameraSW()傪屇傃弌偡偙偲偱丄0.1昩偩偗僜僼僩僇儊儔SW傪ON偵偡傞丅
******************************************************************************************/
on sysvar sysvar::VERI::CameraSoftSW {    // VERI僷僱儖偺乽僇儊儔僜僼僩SW乿儃僞儞偵懳墳
  if (sysGetVariableInt(sysvar::VERI::CameraSoftSW) == 0) {
    return ;
  }else{
    SoftCameraSW();
  }
}

/*****************************************************************************************
 娭悢 SoftCameraSW_Script()  (僜僼僩僇儊儔僗僀僢僠 (僗僋儕僾僩偐傜偺屇傃弌偟梡乯)
    摦嶌 壓婰偺signal SW_PVM傪1偵偟偰丄100ms屻偵0偵偡傞丅
    懳徾僷僱儖丗 PVM_Panel
    懳徾僐儞僩儘乕儖丗僇儊儔僜僼僩SW墴壓忣曬
    懳徾曄悢丗丂signal DSBus::CGW_D::AVN1S73::SW_PVM
******************************************************************************************/
void SoftCameraSW_Script() { // 僗僋儕僾僩偐傜屇傃弌偝傟偨帪梡偺娭悢 愝掕昩悢偺娫丄僗僋儕僾僩幚峴傪巭傔傞
  setSignal(G2M1::BDL::ZN11S26::HSW_PVM, 1); // 婛懚偺忬懺偵偐偐傢傜偢侾偵偡傞
  setTimer(msSW_PVM_from_SCRIPT,100);                       // 100ms偁偲偵僔僌僫儖傪0偵偡傞丅
  write("CAMERA_ON at SoftCameraSW_SCript");
}

/*****************************************************************************************
 僞僀儅乕僀儀儞僩僴儞僪儔 msSW_PVM_from_SCRIPT   
    娭悢SoftCameraSW_Script()偱ON偵偟偨僔僌僫儖SW_PVM傪丄僞僀儅乕僇僂儞僩傾僢僾屻偵0偵偡傞
******************************************************************************************/
on timer msSW_PVM_from_SCRIPT {
  cancelTimer (msSW_PVM_from_SCRIPT);
  setsignal(G2M1::BDL::ZN11S26::HSW_PVM,0);
  setTimer(msExecInterval, CommandInterval);
  alive_msExecInterval = 1;
  write("CAMERA_OFF and msExecInterval set at SoftCameraSW_SCript");
  
}
/*****************************************************************************************
 岺応挷惍丂
--------------------------------------------------------------------------------
 僔僗僥儉曄悢僀儀儞僩僴儞僪儔 VERI::MICO04   
    摦嶌丗VERI僷僱儖偺岺応挷惍儃僞儞偑墴偝傟偨帪偵屇偽傟傞僴儞僪儔
          儃僞儞偺壓偵僗僥乕僞僗傪昞偡儔僕僆儃僞儞偑15屄暲傫偱偍傝丄偙傟傪僋儕傾偡傞丅
          岺応挷惍偼丄15偺僗僥僢僾偐傜峔惉偝傟丄僌儘乕僶儖曄悢FactoryAdjustStep偵偰偳偺僗僥僢僾偵偄傞偐傪帵偡
          娭悢FactoryAdjust()偵偰丄岺応挷惍傪幚峴偡傞丅
******************************************************************************************/
on sysvar sysvar::VERI::MICO4 {  // 岺応挷惍梡偺價儏乕僨乕僞曗惓偺慜弨旛
  if ((sysGetVariableInt(sysvar::VERI::MICO4) == 0 ) && (FactoryAdjustStep != 0) ){
    return ;
  } else {
    sysSetVariableInt(sysvar::VERI::Factory::S01,0);
    sysSetVariableInt(sysvar::VERI::Factory::S02,0);
    sysSetVariableInt(sysvar::VERI::Factory::S03,0);
    sysSetVariableInt(sysvar::VERI::Factory::S04,0);
    sysSetVariableInt(sysvar::VERI::Factory::S05,0);
    sysSetVariableInt(sysvar::VERI::Factory::S06,0);
    sysSetVariableInt(sysvar::VERI::Factory::S07,0);
    sysSetVariableInt(sysvar::VERI::Factory::S08,0);
    sysSetVariableInt(sysvar::VERI::Factory::S09,0);
    sysSetVariableInt(sysvar::VERI::Factory::S10,0);
    sysSetVariableInt(sysvar::VERI::Factory::S11,0);
    sysSetVariableInt(sysvar::VERI::Factory::S12,0);
    sysSetVariableInt(sysvar::VERI::Factory::S13,0);
    sysSetVariableInt(sysvar::VERI::Factory::S14,0);
    sysSetVariableInt(sysvar::VERI::Factory::S15,0);
    FactoryAdjustStep = 0;
    FactoryAdjust();   
    return ;
  }
}

/*****************************************************************************************
 僞僀儅乕僀儀儞僩僴儞僪儔 myFactoryRespTimer
    摦嶌丗FactoryAdjust()娭悢偺拞偱丄SID10_ADU僷僱儖丄SID2E_PVM丄SID3E_ADU僷僱儖偺拞偺憲怣儃僞儞偑墴偝傟偨応崌偺儃僞儞傪棧偡張棟
         乮幚嵺偵墴偡偺偱偼側偔丄憲怣儃僞儞傪墴偡偲丄妱傝摉偰傜傟偰偄傞僔僗僥儉曄悢偑1偵僙僢僩偝傟傞偺偱丄
          偙偺僴儞僪儔偑屇傃弌偝傟偨僞僀儈儞僌偱丄妱傝摉偰傜傟偨僔僗僥儉曄悢傪0偵偡傞偙偲偱儃僞儞傪棧偟偨帪偺摦嶌傪偝偣傞 
******************************************************************************************/
on timer msFactoryRespTimer { // 岺応挷惍娭學偺憲怣儃僞儞傪棧偡 
  putValue(EnvSID3E_Tx_ADU,0); 
  putValue(EnvSID3E_Stop_ADU,0);
  putValue(EnvSID10_Tx_ADU,0);
  putValue(EnvSID2E_Tx_PVM,0);

  cancelTimer(msFactoryRespTimer) ;
  write("憲怣");
}

/*****************************************************************************************
// 娐嫬曄悢僀儀儞僩僴儞僪儔 EnvSID3E_Resp_Flag_ADU
//    摦嶌丗SID3E_ADU僷僱儖偺拞偺峬掕墳摎丄斲掕墳摎偵妱傝摉偰傜傟偰偄傞娐嫬曄悢EnvSID3E_Resp_Flag_ADU偑曄壔偟偨応崌偺僀儀儞僩僴儞僪儔
//          SID3E_ADU偵偰憲怣儃僞儞傪墴偟丄儗僗億儞僗傪庴怣偟偨偲偒偵丄儗僗億儞僗偺庬椶偵墳偠偰丄偙偺娐嫬曄悢偺抣偑曄傢傞乮SID3E_ADU僷僱儖忋偺儔僕僆儃僞儞(峬掕乛斲掕乯偵昞帵乯
//          偙偺娐嫬曄悢偵丄126乮峬掕乯傑偨偼丄127乮斲掕乯偑庴怣偝傟傞偙偲偱丄SID3E_ADU偺僐儅儞僪儗僗億儞僗偑摼傜傟偨偙偲偵側傞偺偱丄
//          岺応挷惍偺師偺僗僥僢僾偵恑傓乮FactoryAdjust()娭悢傪屇傃弌偡乯
******************************************************************************************/
on envVar EnvSID3E_Resp_Flag_ADU {
  write("SID3E_Resp_Flag: %d (FactoryAdjustStep %d) ", getValue(EnvSID3E_Resp_Flag_ADU) ,FactoryAdjustStep);
  if (FactoryAdjustStep == 1) {
    if ((getValue(EnvSID3E_Resp_Flag_ADU) == 126)/*峬掕*/ || (getValue(EnvSID3E_Resp_Flag_ADU) == 127)/*斲掕*/) {
      FactoryAdjust(); // 峬掕偱傕斲掕偱傕偄偭偨傫恑傓
      return;
    }
  }
// 丂岺応挷惍偵偰SID3E偺憲怣掆巭傪傗傔偨乮巙搚抧偝傫傾僪僶僀僗)
//  if (FactoryAdjustStep == 15) { // SID3E_ADU 捠怣掆巭儃僞儞傪墴偟偰傕峬掕傕斲掕傕婣偭偰偙偢侽偵側傞丅
//    if (getValue(EnvSID3E_Resp_Flag_ADU) == 0) {
//      FactoryAdjust(); // 峬掕偱傕斲掕偱傕偄偭偨傫恑傓
//      return;
//    }
//  }
//  write("偙偙偵偼棃側偄");  // 嵟弶偺僗僥僢僾偐嵟屻偺僗僥僢僾偱側偗傟偽壗傕偟側偄
}

/*****************************************************************************************
// 娐嫬曄悢僀儀儞僩僴儞僪儔 EnvSID10_Resp_Flag_ADU
//    摦嶌丗SID10_ADU僷僱儖偺拞偺峬掕墳摎丄斲掕墳摎偵妱傝摉偰傜傟偰偄傞娐嫬曄悢EnvSID10_Resp_Flag_ADU偑曄壔偟偨応崌偺僀儀儞僩僴儞僪儔
//          SID10_ADU偵偰憲怣儃僞儞傪墴偟丄儗僗億儞僗傪庴怣偟偨偲偒偵丄儗僗億儞僗偺庬椶偵墳偠偰丄偙偺娐嫬曄悢偺抣偑曄傢傞乮SID10_ADU僷僱儖忋偺儔僕僆儃僞儞(峬掕乛斲掕乯偵昞帵乯
//          偙偺娐嫬曄悢偵丄80乮峬掕乯傑偨偼丄127乮斲掕乯偑庴怣偝傟傞偙偲偱丄SID3E_ADU偺僐儅儞僪儗僗億儞僗偑摼傜傟偨偙偲偵側傞偺偱丄
//          岺応挷惍偺師偺僗僥僢僾偵恑傓乮FactoryAdjust()娭悢傪屇傃弌偡乯
******************************************************************************************/
on envVar EnvSID10_Resp_Flag_ADU {
  write("SID10_Resp_Flag: %d ", getValue(EnvSID10_Resp_Flag_ADU));
  if ((getValue(EnvSID10_Resp_Flag_ADU) == 80)/*峬掕*/ || (getValue(EnvSID3E_Resp_Flag_ADU) == 127)/*斲掕*/) {
      FactoryAdjust(); // 峬掕偱傕斲掕偱傕偄偭偨傫恑傓
  }
}

/*****************************************************************************************
// 娐嫬曄悢僀儀儞僩僴儞僪儔 EnvSID2E_Resp_Flag_PVM
//    摦嶌丗SID2E_PVM僷僱儖偺拞偺峬掕墳摎丄斲掕墳摎偵妱傝摉偰傜傟偰偄傞娐嫬曄悢EnvSID2E_Resp_Flag_PVM偑曄壔偟偨応崌偺僀儀儞僩僴儞僪儔
//          SID2E_ADU偵偰憲怣儃僞儞傪墴偟丄儗僗億儞僗傪庴怣偟偨偲偒偵丄儗僗億儞僗偺庬椶偵墳偠偰丄偙偺娐嫬曄悢偺抣偑曄傢傞乮SID2E_ADU僷僱儖忋偺儔僕僆儃僞儞(峬掕乛斲掕乯偵昞帵乯
//          偙偺娐嫬曄悢偵丄110乮峬掕乯傑偨偼丄127乮斲掕乯偑庴怣偝傟傞偙偲偱丄SID2E_PVM偺僐儅儞僪儗僗億儞僗偑摼傜傟偨偙偲偵側傞偺偱丄
//          岺応挷惍偺師偺僗僥僢僾偵恑傓乮FactoryAdjust()娭悢傪屇傃弌偡乯
******************************************************************************************/
on envVar EnvSID2E_Resp_Flag_PVM {
  write("EnvSID2E_Resp_Flag_PVM %d", getValue(EnvSID2E_Resp_Flag_PVM));
  if ((getValue(EnvSID2E_Resp_Flag_PVM) == 110)/*峬掕*/) { // || (getvalue(EnvSID2E_Resp_Flag_PVM) == 127)/*斲掕*/) {
      FactoryAdjust(); //丂峬掕偺帪偵師傊恑傓
  }
}
