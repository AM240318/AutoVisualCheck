//  strncat(InputScriptFile, testnum_str, elcount(InputScriptFile));
//  write("僗僋儕僾僩僼傽僀儖 %s傪奐偒傑偟偨",InputScriptFile);
//  strncat(InputScriptFile, ".", elcount(InputScriptFile));
  
  
