on start {
  sysSetVariableInt(sysvar::VERI::BA_ON,0);
  sysSetVariableInt(sysvar::VERI::IG_ON,0);
  sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,-1);
  updateLastBackViewText(-1);
  sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,-1);
  updateLastFrontViewText(-1);
  sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,-1);
  updateAutoDispMode(-1);
  sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,-1);
  updateCameraViewAutoOff(-1);
  ScriptFileOpened = 0;
  alive_msMultiScript = 0;
  CommandInterval = 0; //コマンドの実行間隔 変更するには、interval コマンドで変更
  openPanel("TEST_EXEC");
  sysSetVariableInt(sysvar::VERI::TouchPanelAvailable,0); // タッチパネル無効
  sysSetVariableString(sysvar::VERI::RecordingCaseNo,"");
  sysSetVariableString(sysvar::VERI::RecordingRepeat,"");
  sysSetVariableString(sysvar::VERI::RecordingTag,"");
  sysSetVariableString(sysvar::VERI::RecordingOperationId,"");
  sysSetVariableString(sysvar::VERI::RecordingCommandState,"IDLE");
  sysSetVariableString(sysvar::VERI::RecordingCommandReason,"NOT_STARTED");
  sysSetVariableString(sysvar::VERI::RecordingMp4SelectionMode,"NOT_APPLICABLE");
  // Piggy専用とする。以下実施2025/9/4 (VHを外す）
  //  １）CANoe設定変更：  テスト：テスト環境から、PowerControlを外す
  //  ２）以下２行を追加
//  sysSetVariableInt(sysvar::VERI::VHorIOpiggy,1); // VHが接続されてない場合、I/O piggyがあるものとして動作させる
//  write("I/O piggyとして動作");
  write("あああ");
}


/*****************************************************************************************
システム変数イベントハンドラ  VERI::ScriptFile
  概要  TEST_EXECパネルのスクリプトファイルを指定するPathDialogコントロールに別のスクリプトファイルが指定された場合に、ファイルをクローズします。
  詳細  スクリプトファイルを指定するPathDialog(ファイル名表示とファイルを指定するボタンを組み合わせたもの）で、
        別ファイルを指定した場合にこのハンドラが呼ばれるので、開いていたスクリプトファイルのファイルハンドルをクローズします。
******************************************************************************************/
on sysvar VERI::ScriptFile {  // スクリプトファイルが変わったら、ファイルを閉じる
  if (alive_msRecordingCommand == 1) {
    cancelTimer(msRecordingCommand);
    alive_msRecordingCommand = 0;
  }
  fileClose(ScriptFileHandle);
  ScriptFileOpened=0;
}

//on sysvar VERI::sysInputFolder { // 入力フォルダが変わったら、FileList を閉じる
  
//--------------------------------------------------------------------------------
// 関数 ReadScript 
//    動作：Buffer[]に読み込み済みのスクリプトの１行をコマンドとパラメータに分解する
//    戻り値：1: 正常に分解できた。 0: コマンド異常
//    引数：なし
//    詳細：グローバル変数 Buffer[]の中身を、タブ区切りで３つに分解し、
//         それぞれをグローバル変数 scrCommand[],scrParam1[],scrParam2[]に格納する。
//--------------------------------------------------------------------------------
void ReadScript() {  // グローバル変数Bufferに読み込んだスクリプト１行の文字列処理
  t=0;
  write("scrBufferのサイズ %d",strlen(scrBuffer));
  scrCommand[0] = 0x00;
  scrParam1[0] = 0x00;
  scrParam2[0] = 0x00;
  for (r=0;r<elcount(scrCommand);r++) { //コマンド切り出し ---------------------------------------------------
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)){
      break;
    }
    if ((scrBuffer[t]>0x60)&&(scrBuffer[t]<0x7B)) { //コマンドを大文字にする
      scrCommand[r]=scrBuffer[t]-0x20;
    } else {
      scrCommand[r]=scrBuffer[t];
    }
    t++;
  }
  if (r >= elcount(scrCommand)) {
    r=elcount(scrCommand)-1;  // rが配列長さ以上になった場合、rを領域サイズの最後をさすようにする。　（scrCommandを最大長で切る）
  }
  scrCommand[r]=0x00;
  t++; //　scrBuffer[t]がTabをさしているので次へ
  if (t >= strlen(scrBuffer)){  // tが読み込みBuffer領域以上になった場合
    write("Command読み込み異常 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  for (r=0;r<elcount(scrParam1);r++) { //パラメータ１切り出し -------------------------------------------------
    if (t >= strlen(scrBuffer)) { break ; } // tが読み込み文字列以上になったら処理停止 
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)){
      break;
    }
    scrParam1[r]=scrBuffer[t];
    t++;
  }
  if (r >= elcount(scrParam1)) {
    r=elcount(scrParam1)-1;  // rが配列長さ以上になった場合、rを領域サイズの最後をさすようにする。　（scrParam1を最大長で切る）
  }
  scrParam1[r]=0x00;
  t++; //　scrBuffer[t]がTabをさしているので次へ
  if (t >= strlen(scrBuffer)){  // tがBuffer領域以上になった場合
    write("Param1読み込み異常 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  for (r=0;r<elcount(scrParam2);r++) { //パラメータ2切り出し --------------------------------------------------
    if (t >= strlen(scrBuffer)) { break ; } // tが読み込み文字列以上になったら処理停止 
    if ((scrBuffer[t]==0x09)||(scrBuffer[t]==0x0a)||scrBuffer[t]==0x00){
      break;
    }
    scrParam2[r]=scrBuffer[t];
    t++;
  }
  if (t > strlen(scrBuffer)){  // tがBuffer領域以上になった場合
    write("Param2読み込み異常 t:%d strlen(scrBuffer):%d",t,strlen(scrBuffer));
    return ;
  }
  if (r >= elcount(scrParam2)) {
    r=elcount(scrParam2)-1;  // rが配列長さ以上になった場合、rを領域サイズの最後をさすようにする。　（scrParam1を最大長で切る）
  }
  scrParam2[r]=0x00;
  write ("Read %s, %s, %s",scrCommand,scrParam1,scrParam2);
  return ;
}

void CopyRecordingResultValue(char source[], int sourceOffset, char destination[], int destinationSize) {
  int sourceIndex;
  int destinationIndex;

  destinationIndex = 0;
  for (sourceIndex=sourceOffset;
       (source[sourceIndex] != 0x00) &&
       (source[sourceIndex] != 0x0a) &&
       (source[sourceIndex] != 0x0d) &&
       (destinationIndex < destinationSize-1);
       sourceIndex++) {
    destination[destinationIndex] = source[sourceIndex];
    destinationIndex++;
  }
  destination[destinationIndex] = 0x00;
}

int RecordingTextEquals(char leftText[], char rightText[]) {
  if (strlen(leftText) != strlen(rightText)) {
    return 0;
  }
  if (strncmp(leftText,rightText,strlen(rightText)) != 0) {
    return 0;
  }
  return 1;
}

int ReadRecordingCommandResult() {
  dword resultFileHandle;
  int lineRead;
  int operationIdFound;
  int commandFound;
  int stateFound;

  RecordingResultOperationId[0] = 0x00;
  RecordingResultCommand[0] = 0x00;
  RecordingResultState[0] = 0x00;
  RecordingResultReason[0] = 0x00;
  RecordingResultMp4SelectionMode[0] = 0x00;
  operationIdFound = 0;
  commandFound = 0;
  stateFound = 0;

  resultFileHandle = openFileRead("C:\\Users\\TMC\\Desktop\\Veri\\batfile\\recording_command.result",0);
  if (resultFileHandle == 0) {
    return 0;
  }

  lineRead = fileGetString(RecordingResultLine,elCount(RecordingResultLine),resultFileHandle);
  while (lineRead != 0) {
    if (strncmp(RecordingResultLine,"OperationId=",12) == 0) {
      CopyRecordingResultValue(RecordingResultLine,12,RecordingResultOperationId,elCount(RecordingResultOperationId));
      operationIdFound = 1;
    } else if (strncmp(RecordingResultLine,"Command=",8) == 0) {
      CopyRecordingResultValue(RecordingResultLine,8,RecordingResultCommand,elCount(RecordingResultCommand));
      commandFound = 1;
    } else if (strncmp(RecordingResultLine,"State=",6) == 0) {
      CopyRecordingResultValue(RecordingResultLine,6,RecordingResultState,elCount(RecordingResultState));
      stateFound = 1;
    } else if (strncmp(RecordingResultLine,"Reason=",7) == 0) {
      CopyRecordingResultValue(RecordingResultLine,7,RecordingResultReason,elCount(RecordingResultReason));
    } else if (strncmp(RecordingResultLine,"Mp4SelectionMode=",17) == 0) {
      CopyRecordingResultValue(RecordingResultLine,17,RecordingResultMp4SelectionMode,elCount(RecordingResultMp4SelectionMode));
    }
    lineRead = fileGetString(RecordingResultLine,elCount(RecordingResultLine),resultFileHandle);
  }
  fileClose(resultFileHandle);

  if ((operationIdFound == 0) ||
      (RecordingTextEquals(RecordingResultOperationId,RecordingOperationId) == 0)) {
    return 0;
  }

  if ((commandFound == 0) ||
      (RecordingTextEquals(RecordingResultCommand,RecordingExpectedCommand) == 0)) {
    snprintf(RecordingResultReason,elCount(RecordingResultReason),"RESULT_COMMAND_MISMATCH");
    sysSetVariableString(sysvar::VERI::RecordingCommandState,"FAILED");
    sysSetVariableString(sysvar::VERI::RecordingCommandReason,RecordingResultReason);
    return -1;
  }

  if (stateFound == 0) {
    snprintf(RecordingResultReason,elCount(RecordingResultReason),"RESULT_STATE_MISSING");
    sysSetVariableString(sysvar::VERI::RecordingCommandState,"FAILED");
    sysSetVariableString(sysvar::VERI::RecordingCommandReason,RecordingResultReason);
    return -1;
  }

  if (strlen(RecordingResultReason) == 0) {
    snprintf(RecordingResultReason,elCount(RecordingResultReason),"RESULT_REASON_MISSING");
  }
  if (strlen(RecordingResultMp4SelectionMode) == 0) {
    snprintf(RecordingResultMp4SelectionMode,elCount(RecordingResultMp4SelectionMode),"NOT_APPLICABLE");
  }

  sysSetVariableString(sysvar::VERI::RecordingCommandState,RecordingResultState);
  sysSetVariableString(sysvar::VERI::RecordingCommandReason,RecordingResultReason);
  sysSetVariableString(sysvar::VERI::RecordingMp4SelectionMode,RecordingResultMp4SelectionMode);

  if ((RecordingTextEquals(RecordingResultState,"SUCCEEDED") == 1) ||
      (RecordingTextEquals(RecordingResultState,"DEGRADED") == 1)) {
    return 1;
  }
  if (RecordingTextEquals(RecordingResultState,"FAILED") == 1) {
    return -1;
  }

  snprintf(RecordingResultReason,elCount(RecordingResultReason),"INVALID_RESULT_STATE");
  sysSetVariableString(sysvar::VERI::RecordingCommandState,"FAILED");
  sysSetVariableString(sysvar::VERI::RecordingCommandReason,RecordingResultReason);
  return -1;
}

void BeginRecordingCommandWait() {
  RecordingWaitElapsedMs = 0;
  RecordingWaitTimeoutMs = sysGetVariableInt(sysvar::VERI::RecordingCommandTimeoutMs);
  if (RecordingWaitTimeoutMs < 1000) {
    RecordingWaitTimeoutMs = 180000;
  }
  setTimer(msRecordingCommand,100);
  alive_msRecordingCommand = 1;
}

//--------------------------------------------------------------------------------
// 関数 dispatch() 
//    動作：グローバル変数scrCommand[]に格納されたコマンドによって、それぞれの処理を実行する。
//    戻り値： int  1: 次のスクリプト行の実行にすすむ。　CommandInterval待ってから実行
//                      呼び出し元は、次の行の実行のためスクリプト実行タイマーのセットをする）
//                 0: 次のスクリプトの行の実行に進んではダメ。
//                      本関数の中で、次の処理（ウェイト待ちや、コマンド受信）のタイマーをセットする
//                      呼び出し元はスクリプト実行タイマーのセットはしない。
//                 2: 次のスクリプトの行の実行を即時呼び出し
//    引数：なし
//--------------------------------------------------------------------------------

int IsGaibuBaseName(char fullPath[], char expectedName[]) {
  int i;
  int baseStart;
  int fullPathLen;
  int expectedLen;
  int pathChar;
  int expectedChar;

  fullPathLen = strlen(fullPath);
  expectedLen = strlen(expectedName);
  baseStart = 0;

  for (i = 0; i < fullPathLen; i++) {
    if ((fullPath[i] == 0x5C) || (fullPath[i] == 0x2F)) {
      baseStart = i + 1;
    }
  }

  if ((fullPathLen - baseStart) != expectedLen) {
    return 0;
  }

  for (i = 0; i < expectedLen; i++) {
    pathChar = fullPath[baseStart + i];
    expectedChar = expectedName[i];

    if ((pathChar > 0x60) && (pathChar < 0x7B)) {
      pathChar = pathChar - 0x20;
    }
    if ((expectedChar > 0x60) && (expectedChar < 0x7B)) {
      expectedChar = expectedChar - 0x20;
    }
    if (pathChar != expectedChar) {
      return 0;
    }
  }

  return 1;
}

int dispatch() { //戻り値１は次のコマンド待ちへ。０は次のコマンドを待たない（ウェイト、もしくはエラー終了）
  // "BA" :  +BのON/OFF制御  VH:V30, IOPiggy:DOUT0 
  if (strncmp(scrCommand,"BA",strlen(scrCommand))==0) { // BA
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { //                                                // IO piggy で動作している場合
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,1);
      return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {  
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,0);
      return 1;
    } 
    write ("BAの引数不正");
    return 0;
  } 
  if  (strncmp(scrCommand,"IGN",strlen(scrCommand))==0) { // IGN
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { //                                // IO piggyで動作
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,1) ;
        return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,0) ;
      return 1;
    }
    write ("IGNの引数不正");
    return 0;
  } 
  if ((strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0)||(strncmp(scrCommand,"WaitMS",strlen(scrCommand))==0)) {
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------

  // WaitMSの場合のコマンドインターバルをなくすための対策　2026/1/16
  // WaitMS専用タイマーmsWaitTimerを使うのではなく、msExecIntervalの呼び出し時間でWaitをかけるものとする
  // このため、Dispatch内でのWAITMSの処理は不要　また、次の行を即時実行するために、2を返すようにした。
    // 次の行を読む
    //cancelTimer(msExecInterval);
    //alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    msWaitTicks = atol(scrParam1);
    write("Wait %d",msWaitTicks);
    //setTimer(msWaitTimer,msWaitTicks);
    //alive_msWaitTimer = 1;
    //return 0; //コマンド待ちを止める。  
    return 2;  // 2：次のコマンドを即時実行
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
  }
//↓---シグナルの順序対応　260130
  if (strncmp(scrCommand,"P_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,6);
    return 1;
  }
  if (strncmp(scrCommand,"R_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,5);
    return 1;
  }
  if (strncmp(scrCommand,"N_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 3);  
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    return 1;
  }
  if (strncmp(scrCommand,"D_SHIFT",strlen(scrCommand))==0) {
    sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4);  
    setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
    setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,3);
    return 1;
  }
  if (strncmp(scrCommand,"LIGHT",strlen(scrCommand))==0) {
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      setSignal(G2M1::CDC21::AVN1S73::DN_DISP,1);
      return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {
      setSignal(G2M1::CDC21::AVN1S73::DN_DISP,0);
      return 1;
    } 
    write ("Lightの引数不正");
    return 0;
  }
  if (strncmp(scrCommand,"CUSTPVM",strlen(scrCommand))==0) {
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,1);
      return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {
      setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,0);
      return 1;
    } 
    write ("CustPVMの引数不正");
    return 0;
  }
  if (strncmp(scrCommand,"TOUCHTP",strlen(scrCommand))==0) {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,atol(scrParam1));
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,atol(scrParam2));    
    return 1;
  }
  if (strncmp(scrCommand,"RELTP",strlen(scrCommand))==0) {
    setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
    setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
    return 1;
  }
  if (strncmp(scrCommand,"SHIMUKE",strlen(scrCommand))==0) {
    if (strncmp(scrParam1,"JPN",strlen(scrParam1))==0) { // 
      putValue(SigDt_BDB1S08_C_CODE123,0x0) ; // 国
      putValue(SigDt_BDB1S08_STRG_WHL,2);     // ハンドル
      putValue(SigDt_AVN1S20_A_LANG,0x0);     // 言語
      return 1;
    } 
    if (strncmp(scrParam1,"USA",strlen(scrParam1))==0) { // 
      putValue(SigDt_BDB1S08_C_CODE123,0x104) ;
      putValue(SigDt_BDB1S08_STRG_WHL,1);
      putValue(SigDt_AVN1S20_A_LANG,0x1);
      return 1;
    } 
    if (strncmp(scrParam1,"CHI",strlen(scrParam1))==0) { // 
      putValue(SigDt_BDB1S08_C_CODE123,0x707) ;
      putValue(SigDt_BDB1S08_STRG_WHL,1);
      putValue(SigDt_AVN1S20_A_LANG,0x10);
      return 1;
    } 
    if (strncmp(scrParam1,"GER",strlen(scrParam1))==0) { // 
      putValue(SigDt_BDB1S08_C_CODE123,0x427) ;
      putValue(SigDt_BDB1S08_STRG_WHL,1);
      putValue(SigDt_AVN1S20_A_LANG,0x04);
      return 1;
    } 
    write ("Shimukeの引数不正");
    return 0;
  }
  if (strncmp(scrCommand,"CDSIZE",strlen(scrCommand))==0) {
//    write("CDSize %d", strlen(scrParam1));
    putValue(SigDt_AVN1S73_CD_SIZE,atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"U4C_CAMERA",strlen(scrCommand))==0) {
    putValue(SigDt_ZN11S69_VSI_U4C, atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"U4Y_WASHER",strlen(scrCommand))==0) {
    putValue(SigDt_ZN11S69_VSI_U4Y, atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"B3N_TOWING",strlen(scrCommand))==0) {
    putValue(SigDt_ZN11S49_VSI_B3N, atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"DA03",strlen(scrCommand))==0) { //仕様情報切替
    putValue(EnvSID31_RID_Tx_IOL, 0xDA03);
    putValue(EnvSID31_Type_IOL,1);
    putValue(EnvSID31_RspNecessity_IOL,0);
    putValue(EnvSID31_Tx_IOL,1);
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"T127B",strlen(scrCommand))==0) { //$127B：光軸調整値初期化開始要求
