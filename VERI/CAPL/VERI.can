    write("ファイルリスト %sが開けません %d",InputFileList);
  }
  write("FileList: %s:", InputFileList);
  FileListOpened = 1;
  MultiScriptMode = 1;
  setTimer(msMultiScript,1); // 1ms後にファイル読み込み実行
  alive_msMultiScript = 1;
  //フォルダの中のファイルを探すため、文字列をつなげる
//  testnum = 1;
//  sysGetVariableString(sysvar::VERI::sysInputFolder, InputScriptFile ,elcount(InputScriptFile));
//  snprintf(InputScriptFile,elcount(InputScriptFile),"%s\\%d.txt",InputScriptFile,testnum);
//  FileListHandle = openFileRead(In
//  ltoa(testnum, testnum_str, 10);
//  write("スクリプトファイル %sを開きました",InputScriptFile);
//  strncat(InputScriptFile, "\\", elcount(InputScriptFile));
//  write("スクリプトファイル %sを開きました",InputScriptFile);
//  strncat(InputScriptFile, testnum_str, elcount(InputScriptFile));
//  write("スクリプトファイル %sを開きました",InputScriptFile);
//  strncat(InputScriptFile, ".", elcount(InputScriptFile));
  
  
//  n=fileGetString(ScrFileName,elCount(ScrFileName),FileListHandle);
//  if (n==0) {
//    write("ファイルリストが読めません");
//  }
    /*
  sysGetVariableString(sysvar::VERI::ScriptFile, InputScriptFile ,elcount(InputScriptFile));
  write("TestScript:%s",InputScriptFile);
  ScriptFileHandle = openFileRead(InputScriptFile,0); //  ASCIIモードでファイルを開く
  if (ScriptFileHandle==0) {
    write("スクリプトファイル %sが開けません %d",InputScriptFile, ScriptFileHandle);
  }
  ScriptFileOpened = 1;
  ReadScript();
  ShowCommand(scrCommand,scrParam1,scrParam2);
  if (strncmp(scrCommand,"Interval",strlen(scrCommand))==0) {
    CommandInterval=atol(scrParam1); // ほんとはParam1の範囲をチェックしたほうがよい。最初に絶対にInterValを入れる。１行目を読み飛ばしてしまうため
    write("INT: %d",CommandInterval);
  }
  sysSetVariableInt(sysvar::VERI::CMDITVL, CommandInterval);
  settimer(msExecInterval,CommandInterval);
  */
}

on timer msMultiScript {
  n=fileGetString(ScrFileName,elCount(ScrFileName),FileListHandle);
  for (t=0;t<elcount(ScrFileName);t++) { 
    if (ScrFileName[t]==0x0a) { ScrFileName[t]=0x00; }
  }
//  write("msMultiScript Handler %d",n);
  if (n==0) { // 0が帰ってきたらFileListの終端
    ShowCommand("連続実行終了","","");
    write("~~~連続実行終了~~~");
    cancelTimer(msMultiScript);
    alive_msMultiScript = 0;
    MultiScriptMode = 0;
    fileClose(FileListHandle);
    FileListOpened = 0;
    return;
  }
  snprintf(InputScriptFile,elcount(InputScriptFile),"%s\\%s",InputFolder,ScrFileName);
  CancelTimer(msMultiScript);
  alive_msMultiScript = 0;
  write("%s",ScrFileName);
  write("TestScript:%s",InputScriptFile);
  ExecScript(InputScriptFile);
}

//--------------------------------------------------------------------------------
// 関数 execScript( スクリプトファイル名 ) 
//    動作：引数で渡されたスクリプトファイルを開いて、コマンド実行周期INTERVALコマンドが入った１行目を読み出し、コマンド実行周期をセットし、２行目以降のスクリプトを実行させる。
//    戻り値： なし
//    引数：スクリプトファイル名
//--------------------------------------------------------------------------------
void ExecScript(char ScriptFileName[]) { // 引数で受け取ったスクリプトファイルを実行する。
  write ("ExecScript %s",ScriptFileName);
  ScriptFileHandle = openFileRead(ScriptFileName,0); //  ASCIIモードでファイルを開く
  if (ScriptFileHandle==0) {
    write("スクリプトファイル %sが開けません %d",ScriptFileName, ScriptFileHandle);
  }
  ScriptFileOpened = 1;
  n=fileGetString(scrBuffer,elCount(scrBuffer),ScriptFileHandle);
  if (n==0) {
    write("スクリプトファイルが読めません");
  }
  ReadScript();
  ShowCommand(scrCommand,scrParam1,scrParam2);
  if (strncmp(scrCommand,"INTERVAL",strlen(scrCommand))==0) {
    CommandInterval=atol(scrParam1); // ほんとはParam1の範囲をチェックしたほうがよい。最初に絶対にInterValを入れる。１行目を読み飛ばしてしまうため
    write("INT: %d",CommandInterval);
  }
  sysSetVariableInt(sysvar::VERI::CMDITVL, CommandInterval);
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
  // WaitMSの場合のコマンドインターバルをなくすための対策　2026/1/16
  // 次の行を読む
  n=fileGetString(scrBuffer,elcount(scrBuffer),ScriptFileHandle);
  CommandStored = n; //コマンド読み込み結果
  if (n==0) {
    write("Intervalコマンドの次の行が読めません");
  }
  ReadScript();
  ShowCommand(scrCommand,scrParam1,scrParam2);
  if (strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0) {
    //msWaitTicks = atol(scrParam1);
    //write("WAITMS: %d",msWaitTicks);
    setTimer(msExecInterval,0);
    alive_msExecInterval = 1;
    return;
  }
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
  settimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
}

//--------------------------------------------------------------------------------
// 関数 ShowCommand( コマンド文字列、パラメータ１文字列、パラメータ２文字列 ) 
//    動作：引数で渡されたコマンド文字列、パラメータ１文字列、パラメータ２文字列を、CANoeのWriteウィンドウに出力する（動作確認用）
//    戻り値： なし
//    引数：コマンド文字列、パラメータ１文字列、パラメータ２文字列
//--------------------------------------------------------------------------------

void ShowCommand(char mycmd[],char myp1[], char myp2[]) {
  sysSetVariableString(sysvar::VERI::cmd,mycmd);
  sysSetVariableString(sysvar::VERI::param1,myp1);
  sysSetVariableString(sysvar::VERI::param2,myp2);
}


on timer msExecInterval {
//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------

  if (CommandStored == 0) { // コマンドが読み込み済みならDispatchを実行する　260204
    write("~~~遅延実行終了~~~");
    canceltimer(msExecInterval);
    alive_msExecInterval = 0;
    return;
  }
  currentMyTime = timeNow()/100000.0 ;
  write ("◆%f◆Execute %s, %s, %s",currentMyTime,scrCommand,scrParam1,scrParam2);
  ShowCommand(scrCommand,scrParam1,scrParam2);
  NextInterval = dispatch(); // コマンド実行 戻り値が１でなければウェイトか実行エラーなので次の実行タイマーの待ちには入らない
     //NextInterval dispatchの戻り値
     //             0: コマンドインターバルタイマーセットしない（別のタイマーが作動中）
     //             1: コマンドインターバルタイマーを、CommandIntervalでセットする（次のコマンド実行を待つ）
     // 　　　　　　 2: コマンドインターバルタイマーを、0でセットする。即時呼び出し (dispatchでWAITMSを実行した時の戻り値）
  // 次の行読み込み
  // NextIntervalが0で帰ってきても次の行を読み込んでしまっている。要検討
  n=fileGetString(scrBuffer,elCount(scrBuffer),ScriptFileHandle);
  CommandStored = n; // コマンド読み込み結果　260206
  if (n==0) { // 0が帰ってきたらファイル終端
    ShowCommand("終了","","");
    write("~~~終了~~~");
    ScriptFileOpened = 0;
    fileClose(ScriptFileHandle);
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
    if ( MultiScriptMode== 1) { // 複数ファイル実行中の場合次のファイル読み込み
      setTimer(msMultiScript,1);
      alive_msMultiScript = 1;
    }
    return ;
  }
  ReadScript(); // コマンド分解
  if (strlen(scrCommand) == 0) {  // 空行読み込み時も終了
    write("~~~空行読み込み 実行終了~~~");
    CommandStored = 0;
    canceltimer(msExecInterval);
    alive_msExecInterval = 0;
    return;    
  }
//  write("%d",strlen(scrCommand));
  write("%d%",NextInterval);
  switch (NextInterval){
    case 1:                        //1: 次の行を実行。次行がWAITMSなら即実行、通常行ならCommandInterval待ち
      write("ここは1ばん");
      if (strncmp(scrCommand,"WAITMS",strlen(scrCommand))==0) { //次の行がWAITMSの時の処理
        write("WAITMSのほう");
        settimer(msExecInterval,0);
        alive_msExecInterval = 1;
      } else {
        write("WAITMSじゃないほう");
        settimer(msExecInterval,CommandInterval);
        alive_msExecInterval = 1;
      }
      return;
    case 2:                      //2: WAITMS実行の戻り値。次行が通常・WAITMSどちらでもmsWaitTicks待ち
      settimer(msExecInterval,msWaitTicks);
      alive_msExecInterval = 1;
      return;
    case 0:                     //0: 次の行は実行しない（別タイマーで受信）
      canceltimer(msExecInterval);
      alive_msExecInterval = 0;
      return;
    default:
      canceltimer(msExecInterval);
      alive_msExecInterval = 0;
      return;
  }

//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
}

//↓---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------
/*on timer msWaitTimer{
//  write("msWaitTimerハンドラ");
  setTimer(msExecInterval,0);
  alive_msExecInterval = 1;
  cancelTimer(msWaitTimer);
  alive_msWaitTimer = 0;
}
*/
//↑---WaitMSコマンドで、コマンド実行待ちとWait時間を両方待ってしまうため、コマンド実行待ちをウェイト時間に変更------260116------

on timer msIGN_ON_Timer {
//  write("msIGN_ON_Timer");
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msIGN_ON_Timer);
  alive_msIGN_ON_Timer = 0;
}

on timer msCAMERA_SW_Timer {
//  write("msCAMERA_SW_Timer");
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msCAMERA_SW_Timer);
  alive_msCAMERA_SW_Timer = 0;
}

on timer msRespTimer{
  putValue(EnvSID31_Tx_IOL,0);  
  putValue(EnvSID31_Tx_PVM,0);  
  setTimer(msExecInterval,CommandInterval);
  alive_msExecInterval = 1;
  cancelTimer(msRespTimer);
  alive_msRespTimer = 0;
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::BA_ON
  概要  VERIパネルのBA_ONボタンの処理実行をします。
  詳細  VH1160を使ったシステムと、I/OPiggyを使ったシステムで動作が変わります。
        VH1160の場合、システム変数VHDevice::Relay::Relay_V30 に、RELAY_STATE_CLOSE または、RELAY_STATE_OPENをセットします。
        これにより、テストモジュールPowerControlとして組み込まれたモジュールの中で、このシステム変数を見て、
        VH1160のリレー30(VBatt, +Bとして使用）をクローズ（ON）または、オープン（OFF)にします。
        I/OPiggyの場合、システム変数IO::IOPiggy1::DOUT0 に、１(ON) または 0(OFF)をセットします。
        DOUT1をSSRのINPUT側(コイル側）に接続し、SSRのOUTPUT側（接点側）に定電圧電源の＋BとECUの＋Bの間に入れることで、
        ＋BのON/OFF制御を行います。
******************************************************************************************/
on sysvar sysvar::VERI::BA_ON { // +Bボタン    VH:V30, IO piggy DOUT0 
  if (sysGetVariableInt(sysvar::VERI::BA_ON)==1) {
    // write("BA");
    //if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      //write("VH V30 close");
     /*sysSetVariableInt(sysvar::VHdevice::Relay::relay_V30,RELAY_STATE_CLOSE);
    } else { // I/O piggy
      //write("DOUT0 on");
      */
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,1);
/*    
  }
*/
  }else{
/*    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V30,RELAY_STATE_OPEN);
    } else {
*/    
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT0,0);
    }
/* 
    }
*/    
}

/*****************************************************************************************
システム変数イベントハンドラ  VERI::IG_ON
  概要  VERIパネルのIG_ONボタンの処理実行をします。
  詳細  VH1160を使ったシステムと、I/OPiggyを使ったシステムで動作が変わります。
        VH1160の場合、システム変数VHDevice::Relay::Relay_V15 に、RELAY_STATE_CLOSE または、RELAY_STATE_OPENをセットします。
        これにより、テストモジュールPowerControlとして組み込まれたモジュールの中で、このシステム変数を見て、
        VH1160のリレー15(IGN, IGとして使用）をクローズ（ON）または、オープン（OFF)にします。
        I/OPiggyの場合、システム変数IO::IOPiggy1::DOUT1 に、１(ON) または 0(OFF)をセットします。
        DOUT1をSSRのINPUT側(コイル側）に接続し、SSRのOUTPUT側（接点側）に定電圧電源のIGとECUのIGの間に入れることで、
        IGのON/OFF制御を行います。
******************************************************************************************/
on sysvar sysvar::VERI::IG_ON { // IGボタン   VH:V15, I/O piggy DOUT1
  if (sysGetVariableInt(sysvar::VERI::IG_ON)==1) {
    write("IG_ON");
/*    
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V15,RELAY_STATE_CLOSE);
    } else {
*/    
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,1);
/*    
  }
*/    
  }else{
    write("IG_OFF");
/*    
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V15,RELAY_STATE_OPEN);
    } else {                                                  // for I/O piggy
*/    
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT1,0);
    }
/*  
  }
*/    
}

// VH動作時は、VHのV31の出力側のGNDを使って、カメラSWのI/O制御にしている。 V31の入力側のGNDに、ADUのGNDを接続
// IO Piggy 動作時は、DOUT2のON/OFFとする
/*****************************************************************************************
システム変数イベントハンドラ  VERI::GND_ON
  概要  VERIパネルのGNDのトグルボタン、カメラSW（物理）というラベルの処理実行をします。
        ハードウェアのカメラスイッチ（VIEWSW）のON/OFFをします。
  詳細  VH1160を使ったシステムと、I/OPiggyを使ったシステムで動作が変わります。
        VH1160の場合、システム変数VHDevice::Relay::Relay_V31 に、RELAY_STATE_CLOSE または、RELAY_STATE_OPENをセットします。
        これにより、テストモジュールPowerControlとして組み込まれたモジュールの中で、このシステム変数を見て、
        VH1160のリレー31(IGN, IGとして使用）をクローズ（ON）または、オープン（OFF)にします。(31端子と31'端子の間のクローズ／オープン）
        システム接続においては、31端子にADUのGNDを、31'端子にADUのカメラSWの配線を接続します。
        I/OPiggyの場合、システム変数IO::IOPiggy1::DOUT2 に、１(ON) または 0(OFF)をセットします。
        DOUT2をSSRのINPUT側(コイル側）に接続し、SSRのOUTPUT側（接点側）を定電圧電源のIGとECUのカメラSWの配線の間に入れることで、
        カメラＳＷのON/OFF制御を行います。
******************************************************************************************/
on sysvar sysvar::VERI::GND_ON { // PVMSWボタン
  if (sysGetVariableInt(sysvar::VERI::GND_ON)==1) { // ボタン押下 押したとき
/*    
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_CLOSE);
    } else { // for IO piggy
*/
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,1);
/*
    }
*/
  }else{                                            // ボタン話す
/*
    if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) {  // for VH
      sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_OPEN);
    } else {
*/
      sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,0);
/*
    }      
*/
  }
}
/*****************************************************************************************
システム変数イベントハンドラ  VERI::SHIFT_P
  概要  VERIパネルのParkingというラベルのボタンの処理実行をします。 駐車モードきりかえ
  詳細  シフトに関するシステム変数の操作のみ実行します。実際にCAN信号を出すのは、もともとのCFGファイルで実行されます。
        シグナル ZN11S0::REV_SW       → 0
        システム変数 ECT1G01_B_PRNDB   → １
******************************************************************************************/
on sysvar sysvar::VERI::SHIFT_P { //　シフトP
  if (sysGetVariableInt(sysvar::VERI::SHIFT_P)==0) {
    return;   
  }
  sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
  setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
  setSignal(G2M1::DDM21::DDM1S18::PTCURSFT,6);
}

