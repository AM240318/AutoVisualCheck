  //write("aaa"); 
  
}

/***************************************************************************************
//DID13A0取得
//--------------------------------------------------------------------------------
// 関数 outputDiagReq()
//didlow:
//  0xA0 → 13A0(LastBackView)
//  0xA1 → 13A1(LastFrontView)
//  0xA3 → 13A3(AutoDispMode)
//  0xA4 → 13A4(CameraViewAutoOff)
******************************************************************************************/
void outputDiagReq(byte didlow)
{
  DiagReq.id = mkExtId(DIAG_REQ_ID);
  DiagReq.dlc=8;
  
  DiagReq.byte(0) = 0x03;
  DiagReq.byte(1) = 0x22;
  DiagReq.byte(2) = 0x13;
  DiagReq.byte(3) = didlow;
  DiagReq.byte(4) = 0x00;
  DiagReq.byte(5) = 0x00;
  DiagReq.byte(6) = 0x00;
  DiagReq.byte(7) = 0x00;
  output(DiagReq);
}


/*****************************************************************************************
LastBackView3状態表示
-1：未取得
0：ナローバックビュー
1：ワイドバックビュー
*****************************************************************************************/
void updateLastBackViewText(int v){
  if(v == 0) {
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"ナローバックビュー");
  } else if(v == 1){
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"ワイドバックビュー");
  } else {
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"未取得");
  }
}



/**************************************************************************************
パネルボタン：getLastBackView
**************************************************************************************/
on sysvar sysvar::VERI::DID::getLastBackView{
  if (sysGetVariableInt(sysvar::VERI::DID::getLastBackView) == 0) {
    return;
    
  } else if (initViewActive == 1){
    write("INIT_VIEW running");
    return;
    
  } else {
    
    sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,-1);
    updateLastBackViewText(-1);
    
    waitA0 = 1;
    outputDiagReq(0xA0);
    write("send DID13A0");
    
  }
}


