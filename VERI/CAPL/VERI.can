//--------------------------1217埲崀捛婰暘----------------------------------------------

on sysvar sysvar::VERI::Disable_Shift { // 柍岠僔僼僩
  if (sysGetVariableInt(sysvar::VERI::Disable_Shift)==1) { // 儃僞儞墴壓
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_DDM21::MESSAGES::ECT1G01::TIMINGS::EnableCyclic,0);
  }else{                                            // 儃僞儞棧偡
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_DDM21::MESSAGES::ECT1G01::TIMINGS::EnableCyclic,1);      
  }
}
on sysvar sysvar::VERI::Disable_Speed { // 幵懍柍岠
  if (sysGetVariableInt(sysvar::VERI::Disable_Speed)==1) { // 儃僞儞墴壓
      setSignal(G2M1::DDM21::VSC1G13::SP1S,1);
  }else{                                            // 儃僞儞棧偡
      setSignal(G2M1::DDM21::VSC1G13::SP1S,0);     
  }
}
on sysvar sysvar::VERI::Disable_AVN1S73 { // AVN捠怣柍岠
  if (sysGetVariableInt(sysvar::VERI::Disable_AVN1S73)==1) { // 儃僞儞墴壓
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S73::TIMINGS::EnableCyclic,0);
  }else{                                            // 儃僞儞棧偡
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S73::TIMINGS::EnableCyclic,1);
  }
}
on sysvar sysvar::VERI::Disable_Steer { // 懬妏柍岠
  if (sysGetVariableInt(sysvar::VERI::Disable_Steer)==1) { // 儃僞儞墴壓
      setSignal(G5M::DDM_5::EPS1S11::PANGINV,1);
  }else{                                            // 儃僞儞棧偡
      setSignal(G5M::DDM_5::EPS1S11::PANGINV,0);
  }
}
on sysvar sysvar::VERI::PKB { // PKB
  if (sysGetVariableInt(sysvar::VERI::PKB)==1) { // 儃僞儞墴壓
      setSignal(G2M1::BDL::BDB1S01::PKB_BDB,1);
  }else{                                            // 儃僞儞棧偡
      setSignal(G2M1::BDL::BDB1S01::PKB_BDB,0);
  }
}
on sysvar sysvar::VERI::BACKDOOR { // 僶僢僋僪傾
  if (sysGetVariableInt(sysvar::VERI::BACKDOOR)==1) { // 儃僞儞墴壓
      setSignal(G2M1::BDL::BDB1S01::BCTY,1);
  }else{                                            // 儃僞儞棧偡
      setSignal(G2M1::BDL::BDB1S01::BCTY,0);
  }
}

