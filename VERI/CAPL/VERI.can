  詳細  ボタンの左のテキストボックスの値を読み込み、環境変数SigDt_AVN1S73_CD_SIZEへ格納
        具体的にはPVM_Panelの仕様情報のセンターディスプレイサイズのドロップダウンの値が変わります。。
******************************************************************************************/
on sysvar sysvar::VERI::CC10 { // センターディスプレイサイズ　1010b:1280x621(10.5in)
  if (sysGetVariableInt(sysvar::VERI::CC10)==0) { return; }
  screensize=sysGetVariableInt(sysvar::VERI::GamenSize);
  putValue(SigDt_AVN1S73_CD_SIZE,screensize);
}

