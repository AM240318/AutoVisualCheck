    return 1;
  }
  if (strncmp(scrCommand,"CCMODE",strlen(scrCommand))==0) {//AVN1S73(13E)センターディスプレイカメラモード状態
    setSignal(G2M1::CDC21::AVN1S73::CC_MODE,atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"CASENO",strlen(scrCommand))==0) { // ケース番号表示用
    sysSetVariableString(sysvar::VERI::Case1,scrParam1);
    sysSetVariableString(sysvar::VERI::Case2,scrParam2);
    sysSetVariableString(sysvar::VERI::RecordingCaseNo,scrParam1);
    sysSetVariableString(sysvar::VERI::RecordingRepeat,"");
    sysSetVariableString(sysvar::VERI::RecordingTag,"");
    return 1;
  }
  if (strncmp(scrCommand,"REPEAT",strlen(scrCommand))==0) { // リピート回数表示用
    sysSetVariableString(sysvar::VERI::RepCNT1,scrParam1);
    sysSetVariableString(sysvar::VERI::RepCNT2,scrParam2);
    sysSetVariableString(sysvar::VERI::RecordingRepeat,scrParam1);
    return 1;
  }
  if (strncmp(scrCommand,"TAG",strlen(scrCommand))==0) { // 録画識別子
    sysSetVariableString(sysvar::VERI::RecordingTag,scrParam1);
    return 1;
  }
  if (strncmp(scrCommand,"MIRROR",strlen(scrCommand))==0) { // ミラー開閉
    if (strncmp(scrParam1,"OPEN",strlen(scrParam1))==0) { // 
      setSignal(G2M1::BDL::BDB1S04::MRMV_R,0) ;
      return 1;
    } 
    if (strncmp(scrParam1,"CLOSE",strlen(scrParam1))==0) { // 
      setSignal(G2M1::BDL::BDB1S04::MRMV_R,1) ;
      return 1;
    } 
    return 1; //パラメータがどちらでもない場合無視
  }
  if (strncmp(scrCommand,"CAMERASW",strlen(scrCommand))==0) { // カメラスイッチON/OFF　VH制御
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { //       
/*
      if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) { // VHで動作している場合
        sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_CLOSE);
        cancelTimer(msExecInterval);
        alive_msExecInterval = 0;
        setTimer(msCAMERA_SW_Timer, 6); // IG ON　後 6msウェイトを入れる（リレーONに7msかかる。コマンドインターバルを1msと置くと、次のコマンド実行とIGN ONを同じタイミングにできる
        alive_msCAMERA_SW_Timer = 1;    // このあたりIGと同じにしておく
        return 0;
      }else{ // IO piggyで動かしている場合
*/
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,1);
        return 1;
/*
      }
*/
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) { // 
/*
      if (sysGetVariableInt(sysvar::VERI::VHorIOpiggy) == 0) { // VHで動作している場合
        sysSetVariableInt(sysvar::VHdevice::Relay::relay_V31,RELAY_STATE_OPEN);
      } else {
*/
        sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,0);
/*
      }        
*/
      return 1;
    } 
    return 1; // パラメータがどちらでもなければ無視
  }
  if (strncmp(scrCommand,"STEERANGLE",strlen(scrCommand))==0) {//EPS1S11(030)舵角信号ピニオン角
    setSignal(G5M::DDM_5::EPS1S11::PANG,atol(scrParam1));
    return 1;
  }
  if (strncmp(scrCommand,"SPEED",strlen(scrCommand))==0) {//VSC1G13(0D7)車速SP1
    setSignal(G2M1::DDM21::VSC1G13::SP1,atol(scrParam1));
    return 1;
  }

  
  if (strncmp(scrCommand,"GAIBU",strlen(scrCommand))==0) {//外部コマンド実行用
    int previousResultStatus;

    sysGetVariableString(sysvar::VERI::Case1,GaibuCaseNo,elCount(GaibuCaseNo));
    sysGetVariableString(sysvar::VERI::Case2,GaibuTag,elCount(GaibuTag));
    sysGetVariableString(sysvar::VERI::RepCNT1,GaibuRepeat,elCount(GaibuRepeat));
    GaibuArgs[0] = 0x00;

    if ((IsGaibuBaseName(scrParam1,"START_REC.bat") == 1) ||
        (IsGaibuBaseName(scrParam1,"STOP_REC.bat") == 1)) {
      sysGetVariableString(sysvar::VERI::RecordingCaseNo,GaibuCaseNo,elCount(GaibuCaseNo));
      sysGetVariableString(sysvar::VERI::RecordingTag,GaibuTag,elCount(GaibuTag));
      sysGetVariableString(sysvar::VERI::RecordingRepeat,GaibuRepeat,elCount(GaibuRepeat));
      RecordingOperationCounter++;
      snprintf(RecordingOperationId,elCount(RecordingOperationId),"CANOE_%d_%d",timeNow(),RecordingOperationCounter);
      if (IsGaibuBaseName(scrParam1,"START_REC.bat") == 1) {
        snprintf(RecordingExpectedCommand,elCount(RecordingExpectedCommand),"START_REC");
      } else {
        snprintf(RecordingExpectedCommand,elCount(RecordingExpectedCommand),"STOP_REC");
      }
      previousResultStatus = ReadRecordingCommandResult();
      if (previousResultStatus != 0) {
        RecordingOperationCounter++;
        snprintf(RecordingOperationId,elCount(RecordingOperationId),"CANOE_%d_%d",timeNow(),RecordingOperationCounter);
        write("[REC_TIMELINE] Event=CAPL_OPERATION_ID_COLLISION_AVOIDED NewOperationId=%s",RecordingOperationId);
      }
      snprintf(GaibuArgs,elCount(GaibuArgs),"\"%s\" \"%s\" \"%s\" \"%s\"",GaibuCaseNo,GaibuTag,GaibuRepeat,RecordingOperationId);
      sysSetVariableString(sysvar::VERI::RecordingOperationId,RecordingOperationId);
      sysSetVariableString(sysvar::VERI::RecordingCommandState,"PENDING");
      sysSetVariableString(sysvar::VERI::RecordingCommandReason,"WAITING_FOR_BAT");
      sysSetVariableString(sysvar::VERI::RecordingMp4SelectionMode,"NOT_APPLICABLE");
    } else if (IsGaibuBaseName(scrParam1,"START_REC3.bat") == 1) {
      snprintf(GaibuArgs,elCount(GaibuArgs),"\"%s\" \"%s\"",GaibuCaseNo,GaibuTag);
    } else if (IsGaibuBaseName(scrParam1,"STOP_REC2.bat") == 1) {
      snprintf(GaibuArgs,elCount(GaibuArgs),"\"%s\" \"%s\" \"%s\"",GaibuCaseNo,GaibuTag,GaibuRepeat);
    } else if (IsGaibuBaseName(scrParam1,"START_REC2.bat") == 1) {
      GaibuArgs[0] = 0x00;
    }

    if (strlen(GaibuArgs) == 0) {
      write("commandline:%s args:<none>",scrParam1);
    } else {
      write("commandline:%s args:%s",scrParam1,GaibuArgs);
    }
    if ((IsGaibuBaseName(scrParam1,"START_REC.bat") == 1) ||
        (IsGaibuBaseName(scrParam1,"STOP_REC.bat") == 1)) {
      write("[REC_TIMELINE] OperationId=%s Event=CAPL_BEFORE_SYSEXEC TimeNow=%d",RecordingOperationId,timeNow());
    }
    sysExec(scrParam1,GaibuArgs,"C:\\Users\\TMC\\Desktop\\Veri\\batfile");
    if (((IsGaibuBaseName(scrParam1,"START_REC.bat") == 1) ||
         (IsGaibuBaseName(scrParam1,"STOP_REC.bat") == 1)) &&
        (sysGetVariableInt(sysvar::VERI::RecordingHandshakeEnabled) == 1)) {
      BeginRecordingCommandWait();
      return 0;
    }
    return 1;
  }
//---- ディーラー調整画面への遷移 ---  
  if (strncmp(scrCommand,"DEALER",strlen(scrCommand))==0) {//外部コマンド実行用
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      setSignal(G2M1::CDC21::AVN1S73::DI_MODE,1);
      cancelTimer(msExecInterval);
      alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
      setTimer(msDiagTimer,100);
      alive_msDiagTimer = 1;
      return 0; //コマンド待ちを止める。
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) { // 
      setSignal(G2M1::CDC21::AVN1S73::DI_MODE,0);
      setSignal(G2M1::CDC21::AVN1S73::CMD_MODE,0);
      setSignal(G2M1::CDC21::AVN1S73::MMD_MODE,0);
      return 1;
    } 
  }
//MTMモード VSC1S96(427) 
  if (strncmp(scrCommand,"MTM",strlen(scrCommand))==0) {//外部コマンド実行用
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      putValue(SigDt_ENG1G90_B_OMODE,1);
      setSignal(G2M1::DDM21::VSC1G12::V_GXHR0,-0.43);
      setSignal(G2M1::DDM21::VSC1G12::V_GYHR0,-0.43);
      setSignal(G2M1::DDM21::VSC1G12::V_YR1HR0,-3.0);

      return 1;
    } 
    if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) { // 
      putValue(SigDt_ENG1G90_B_OMODE,0);
      setSignal(G2M1::DDM21::VSC1G12::V_GXHR0,-0.43);
      setSignal(G2M1::DDM21::VSC1G12::V_GYHR0,-0.43);
      setSignal(G2M1::DDM21::VSC1G12::V_YR1HR0,-3.0);
      return 1;
    } 
  }

//-----------------------------1217追記分------------------------------------------------------
  
 if (strncmp(scrCommand,"PKB",strlen(scrCommand))==0) {//PKB 251209 ikami
    if (strncmp(scrParam1,"ON",strlen(scrParam1))==0) { // 
      setSignal(G2M1::BDL::BDB1S01::PKB_BDB,1);
      return 1;
    }  else if (strncmp(scrParam1,"OFF",strlen(scrParam1))==0) {
      setSignal(G2M1::BDL::BDB1S01::PKB_BDB,0);
      return 1;
    }
  }
  if (strncmp(scrCommand,"BACKDOOR",strlen(scrCommand))==0) {//PKB 251209 ikami
    if (strncmp(scrParam1,"OPEN",strlen(scrParam1))==0) { // 
      setSignal(G2M1::BDL::BDB1S01::BCTY,1);
      return 1;
    }  else if (strncmp(scrParam1,"CLOSE",strlen(scrParam1))==0) {
      setSignal(G2M1::BDL::BDB1S01::BCTY,0);
      return 1;
    }
  }
  if (strncmp(scrCommand,"DISABLE_SHIFT",strlen(scrCommand))==0) { //シフト無効 251209 ikami
    if (strncmp(scrParam1,"DIS",strlen(scrParam1))==0) {
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_DDM21::MESSAGES::ECT1G01::TIMINGS::EnableCyclic,0);
      return 1;
    }  else if (strncmp(scrParam1,"ENA",strlen(scrParam1))==0) {
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_DDM21::MESSAGES::ECT1G01::TIMINGS::EnableCyclic,1);
      return 1;
    }
  }
  if (strncmp(scrCommand,"DISABLE_SPEED",strlen(scrCommand))==0) {//車速無効 251209 ikami
    if (strncmp(scrParam1,"DIS",strlen(scrParam1))==0) { // 
      setSignal(G2M1::DDM21::VSC1G13::SP1S,1);
      return 1;
    }  else if (strncmp(scrParam1,"ENA",strlen(scrParam1))==0) {
      setSignal(G2M1::DDM21::VSC1G13::SP1S,0);
      return 1;
    }
  }
  if (strncmp(scrCommand,"DISABLE_AVN1S73",strlen(scrCommand))==0) {//AVN通信無効 251209 ikami
    if (strncmp(scrParam1,"DIS",strlen(scrParam1))==0) { // 
      sysSetVariableInt(sysvar::IL_CAN1::NODES::N_CDC21::MESSAGES::AVN1S73::TIMINGS::EnableCyclic,0);
      return 1;
    }  else if (strncmp(scrParam1,"ENA",strlen(scrParam1))==0) {
