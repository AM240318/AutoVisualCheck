    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
    cancelTimer(msExecInterval);
    alive_msExecInterval = 0;
//    write(">Wait %d",atol(scrParam1));
    setTimer(msRespTimer,1);
    alive_msRespTimer = 1;
    return 0; //コマンド待ちを止める。
  }
  if (strncmp(scrCommand,"S127C",strlen(scrCommand))==0) { //$127C：周辺監視システム初期化要求
    putValue(EnvSID31_RID_Tx_PVM, 0x127C);
    putValue(EnvSID31_Type_PVM,1);
    putValue(EnvSID31_RspNecessity_PVM,0);
    putValue(EnvSID31_Tx_PVM,1);  
