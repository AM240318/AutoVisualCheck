/******************************************************************************************
//initview() 初期化関数
******************************************************************************************/
 void initview(){
  //DIDを使って現在値を取得する
  didlow = 0xA0; // DIDの番号
  setTimer(sendDID,20);

}

/******************************************************************************************
//DID取得完了後
//初期値かどうか判断し、InitViewSeqタイマーを使って、初期化する
//initTargetView 0:ラストバックビュー 1:ラストフロントビュー 2:自動表示モード 3:カメラ映像自動
******************************************************************************************/
on sysvar sysvar::VERI::DID::didReceived {
  if (sysGetVariableInt(sysvar::VERI::DID::didReceived) == 0) {
    return;
  } else {
    initTargetView = 0; //初期化ターゲットを0:ラストバックビューから始める
    initViewStep = 1;
    write("初期化開始");

    setTimer(InitViewSeq,initTargetViewInterval);
    sysSetVariableInt(sysvar::VERI::DID::didReceived,0) ;
  }
}

/******************************************************************************************
// ラスト画初期化の処理を行う
//initTargetView 0:ラストバックビュー 1:ラストフロントビュー 2:自動表示モード 3:カメラ映像自動
*******************************************************************************************/
on timer InitViewSeq{
  
  cancelTimer(InitViewSeq);  
  
  if(initTargetView == 0){//　ラストバックビューの初期化処理
    if(ret_BackNum == 1) {               //ラストバックビューの戻り値が１：ワイドバックビューの場合。
//      write("LastBackView:ワイドバックビュー");
      switch(initViewStep){
        case 1:                                       // リバースに入れる
          write("1:リバースに入れる");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                      // ミラーを開く
          write("ミラーを開く");
          setSignal(G2M1::BDL::BDB1S04::MRMV_R,0) ;
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                      // 車速を0kmにする
          write("車速を0kmにする");
          setSignal(G2M1::DDM21::VSC1G13::SP1,0);
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // 画面切り替えボタンを押下する
          write("画面切り替えボタンを押下する");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                      // 画面切り替えボタンを離す
          write("画面切り替えボタンを離す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                     // パーキングに戻す
          write("パーキングに戻す");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 1;                           // 次は1：ラストフロントビューの処理
          initViewStep = 1;                               // カウンタを１に
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID初期化エラー0");
          return;
      }
    } else {                   //ラストバックビューの戻り値が0：ナローバックビューの場合。
      write("元からナローバックビュー");
      initTargetView = 1;                               // 何もせずに、1:ラストフロントビューの処理に進む
      initViewStep = 1; 
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 1) { // ラストフロントビューの初期化処理
    if (ret_FrontNum == 1) {                  // ラストフロントビューの戻り値が1: サイドクリアランスビューの場合。
      switch(initViewStep) {
        case 1:                                         // ドライブに入れる
          write("ドライブに入れる");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                        // ミラー開く
          write("ミラー開く");
          setSignal(G2M1::BDL::BDB1S04::MRMV_R,0) ;
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                      // 車速を0kmにする
          write("車速を0kmにする");
          setSignal(G2M1::DDM21::VSC1G13::SP1,0);
          if (ret_AutoDisp == 1) {  // AutoDispが1:ONの場合、PVMが表示されているため、カメラスイッチを押さない　ラスト画が表示される（サイドフロントビュー）
            initViewStep = 8;       // 画面切替ボタンを１回押す　（ワイドフロントビュー）（ラスト画更新）
          } else {                  // AutoDispが1でない場合、PVMが表示されていないため、カメラスイッチを押す　　ワイドフロントビューが表示される。（固定）
            initViewStep = 4;       // カメラスイッチを押す（ワイドフロント）→　画面切替押下１回目（サイドフロントビュー表示）　→　画面切替押下２回目（ワイドフロントビュー）（これでラスト画が更新）
          }
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // カメラスイッチを押す  (TSS4とBEVでは動きが違うので注意)
          write(" カメラスイッチを押す ");
          setSignal(G2M1::CDC21::AVN1S73::SW_PVM, 1); // 既存の状態にかかわらず1にする
          //          sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,1);
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                      // カメラスイッチを離す  (TSS4とBEVでは動きが違うので注意)
          write("カメラスイッチを離す");
          setSignal(G2M1::CDC21::AVN1S73::SW_PVM, 0); // 既存の状態にかかわらず0にする
          //sysSetVariableInt(sysvar::IO::IOPiggy1::DOUT2,0);
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                      // 画面切り替えボタンを押す　　
          write("画面切り替えボタンを押す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 7;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 7:                                      // 画面切り替えボタンを離す
          write("画面切り替えボタンを離す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 8;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 8:                                      // 画面切り替えボタンを押す　　
          write("画面切り替えボタンを押す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);
          initViewStep = 9;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 9:                                      // 画面切り替えボタンを離す
          write("画面切り替えボタンを離す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 10;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 10:                                      // パーキングに戻す
          write("パーキングに戻す");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 2;                        // 次は2：自動表示モードの処理
          initViewStep = 1;                               // カウンタを１に
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID初期化エラー1");
          return;
      }
    } else {                                 // ラストフロントビューの戻り値が0: ワイドフロントビューの場合
      write("元からワイドフロントビュー");
      initTargetView = 2;                               // 何もせずに、2:自動表示モードーの処理に進む
      initViewStep = 1; 
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 2) { // 自動表示モードの初期化処理　
    if (ret_AutoDisp == 1){             //自動表示モードの戻り値が　1:ONの場合の初期化処理
      switch(initViewStep){
        case 1:                                         //ドライブに入れる
          write("ドライブに入れる");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 4);  
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                         //自動表示ボタンを押す
          write("自動表示ボタンを押す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,1000);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,400);
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                         //自動表示ボタンを離す
          write("自動表示ボタンを離す");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                      // パーキングに戻す
          write("パーキングに戻す");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initTargetView = 3;                         // 次は3: カメラ映像自動OFFの処理
          initViewStep = 1;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID初期化エラー2");
          return;
      }
    } else {                                // 自動表示モードの戻り値が0: OFFの場合（デフォルト)
      write("元から自動表示モードOFF");
      initTargetView = 3;                         // なにもせずに、3:カメラ映像移動オフの設定に進む
      initViewStep = 1;
      setTimer(InitViewSeq,initTargetViewInterval);
      return;
    }
  } else if (initTargetView == 3){ // カメラ映像自動オフの初期化処理  BEVではまったく動きが違いそうなので確認が必要
    if(ret_AutoCamera ==1){           //　カメラ映像自動オフの戻り値が1:OFFの場合の初期化処理   
      switch(initViewStep){
        case 1:                                         // CUST_PVMシグナルをONにする
          write("CUST_PVMシグナルをONにする");
          setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,1);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,1);
          initViewStep = 2;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 2:                                         // CUST_PVMシグナルをOFFにする  設定画面に遷移する   
          write("CUST_PVMシグナルをOFFにする  設定画面に遷移する");
          setSignal(G2M1::CDC21::AVN1S73::CUST_PVM,0);
          initViewStep = 3;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 3:                                         // タッチパネルを押す　（カメラ映像自動オフをONする。（デフォルト値に戻す））
          write("タッチパネルを押す（カメラ映像自動オフをONする。（デフォルト値に戻す））");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,700);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,250);    
          initViewStep = 4;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 4:                                         // タッチパネルを離す　（カメラ映像自動オフをONにする
          write("タッチパネルを離す（カメラ映像自動オフをONにする");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);    
          initViewStep = 5;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 5:                                         // タッチパネルを押す　　（設定画面を抜ける
          write("タッチパネルを押す（設定画面を抜ける");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,160);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,40);    
          initViewStep = 6;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 6:                                         // タッチパネルを離す　（設定画面抜ける
          write("タッチパネルを離す（設定画面抜ける");
          setSignal(G2M1::CDC21::AVN1S73::X_COORD,0);
          setSignal(G2M1::CDC21::AVN1S73::Y_COORD,0);   
          initViewStep = 7;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 7:                                         //リバースに入れる（MM画面に戻らない場合があるため）
          write("リバースに入れる");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 2); 
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,1);
          initViewStep = 8;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 8:                                          //パーキングに戻す
          write("パーキングに戻す");
          sysSetVariableInt(sysvar::PVM::SigDt_ECT1G01_B_PRNDB, 1);
          setSignal(G2M1::DDM21::EHV1G30::BCKLTRQ,0);
          setSignal(G2M1::CDC21::AVN1S73::CC_MODE,0);
          initViewStep = 9;
          setTimer(InitViewSeq,initTargetViewInterval);
          return;
        case 9:                                         //　初期化完了
          write("初期化完了");
          setTimer(msExecInterval,0);                 // 次のスクリプト行の実行に飛ばす 仮にコメントアウト
          alive_msExecInterval = 1;
          //cancelTimer(msExecInterval);
          //alive_msExecInterval = 0;
          initViewActive =0;
          return;
        default:
          cancelTimer(InitViewSeq);
          write("DID初期化エラー3 %d",initViewStep);
          return;
      }
    } 
      else {
      write("元からカメラ自動モードON");
      write("初期化完了");
      setTimer(msExecInterval,0);                 // 次のスクリプト行の実行に飛ばす 仮にコメントアウト
      alive_msExecInterval = 1;
      //cancelTimer(msExecInterval);
      //alive_msExecInterval = 0;
      initViewActive =0;
      return;
     }
  } else { // initTargetView が0から3の間でない場合
    write("!!! ラスト画関連(DID)初期化エラー");
    return;
  }
}
