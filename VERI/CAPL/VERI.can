/*****************************************************************************************
// 娭悢 FactoryAdjust()  SID2E_PVM僷僱儖偱峴偆丄岺応挷惍偺愝掕傪峴偆
//    愢柧 娭學偡傞僐儅儞僪偺庴怣偛偲偵偙偺娭悢偑屇偽傟傞丅
//      僌儘乕僶儖曄悢 FactoryAdjustStep 偵傛偭偰丄FactoryAdjustStep()娭悢偺摦嶌偑曄傢傞
//       FactoryAdjustStep   :   摦嶌
//           0               :   SID3E_ADU僷僱儖偵偰憲怣儃僞儞傪墴偡丅 FactoryAdjustStep傪1偵恑傔偰丄娭悢傪敳偗傞
//                               偙傟偺儗僗億儞僗傪敾掕偡傞EnvSID3E_Resp_Flag_ADU偺僀儀儞僩僴儞僪儔偐傜嵞搙偙偺娭悢偑屇偽傟傞偙偲偱丄
//                               師偺僗僥僢僾偱偁傞 1 偺張棟偑幚峴偝傟傞
//           1               :   SID10_ADU僷僱儖偱丄$01僨僼僅儖僩傪慖戰偟偰憲怣儃僞儞傪墴偡丅FactoryAdjustStep傪2偵恑傔偰娭悢傪敳偗傞
//                               偙傟偺儗僗億儞僗傪敾掕偡傞EnvSID10_Resp_Flag_ADU偺僀儀儞僩僴儞僪儔偐傜嵞搙偙偺娭悢偑屇偽傟傞偙偲偱丄
//                               師偺僗僥僢僾偱偁傞 2 偺張棟偑幚峴偝傟傞
//           2               :   SID10_ADU僷僱儖偱丄$03奼挘傪慖戰偟偰丄憲怣儃僞儞傪墴偡丅FactorAdjustStep傪3偵恑傔偰娭悢傪敳偗傞
//                               偙傟偺儗僗億儞僗傪敾掕偡傞EnvSID10_Resp_Flag_ADU偺僀儀儞僩僴儞僪儔偐傜嵞搙偙偺娭悢偑屇偽傟傞偙偲偱丄
//                               師偺僗僥僢僾偱偁傞 3 偺張棟偑幚峴偝傟傞
//           3               :   SID2E_PVM僷僱儖偱丄$5140 岝幉挷惍忔堳彂偒崬傒傪憲怣偡傞丅FactoryAdjstStep傪4偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾4偵恑傓
//           4               :   SID2E_PVM僷僱儖偱丄$5141 岝幉挷惍敾掕鑷抣   傪憲怣偡傞丅FactoryAdjstStep傪5偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾5偵恑傓
//           5               :   SID2E_PVM僷僱儖偱丄$5142 帺摦岝幉腊罐习栋埵抲(屻曽)傪憲怣偡傞丅FactoryAdjstStep傪6偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾6偵恑傓
//           6               :   SID2E_PVM僷僱儖偱丄$5143 帺摦岝幉腊罐习栋埵抲(慜曽)傪憲怣偡傞丅FactoryAdjstStep傪7偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾7偵恑傓
//           7               :   SID2E_PVM僷僱儖偱丄$5144 帺摦岝幉腊罐习栋埵抲_僶僢僋僇儊儔惓柺儅乕僇乕(岦偒)傪憲怣偡傞丅FactoryAdjstStep傪8偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾8偵恑傓
//           8               :   SID2E_PVM僷僱儖偱丄$5145 帺摦岝幉腊罐习栋埵抲_僶僢僋僇儊儔惓柺儅乕僇乕傪憲怣偡傞丅FactoryAdjstStep傪9偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾9偵恑傓
//           9               :   SID2E_PVM僷僱儖偱丄$5146 帺摦岝幉腊罐习栋埵抲_僼儘儞僩僇儊儔惓柺儅乕僇乕(岦偒)傪憲怣偡傞丅FactoryAdjstStep傪10偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾10偵恑傓
//           10              :   SID2E_PVM僷僱儖偱丄$5147 帺摦岝幉腊罐习栋埵抲_僼儘儞僩僇儊儔惓柺儅乕僇乕傪憲怣偡傞丅FactoryAdjstStep傪11偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾11偵恑傓
//           11              :   SID2E_PVM僷僱儖偱丄$5148 帺摦岝幉腊罐习栋埵抲_僒僀僪僇儊儔惓柺儅乕僇乕(岦偒)岝幉挷惍忔堳彂偒崬傒傪憲怣偡傞丅FactoryAdjstStep傪12偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾12偵恑傓
//           12              :   SID2E_PVM僷僱儖偱丄$5149 帺摦岝幉腊罐习栋埵抲_僒僀僪僇儊儔惓柺儅乕僇乕岝幉挷惍忔堳彂偒崬傒傪憲怣偡傞丅FactoryAdjstStep傪13偵偟偰偍偒丄儗僗億儞僗偑偒偨傜丄師僗僥僢僾13偵恑傓
//           13              :   SID10_ADU僷僱儖偱丄$01僨僼僅儖僩傪慖戰偟偰憲怣儃僞儞傪墴偡丅FactoryAdjustStep15偵偟偰偍偒丄儗僗億儞僗偑棃偨傜丄師僗僥僢僾15傊恑傓
//           14              :   SID3E_ADU僷僱儖偱丄憲怣掆巭傪憲怣偡傞乮晄梫偲偺偙偲側偺偱寚斣乯
//           15              :   僗僋儕僾僩偺師偺峴傪幚峴偡傞偨偊偵丄僗僋儕僾僩幚峴僞僀儅乕 msExecInterval傪僙僢僩偡傞丅師偼僞僀儅乕僴儞僪儔msExecInterval偵偰丄師偺峴傪幚巤偡傞
******************************************************************************************/
void FactoryAdjust() { //岺応挷惍
  write ("FactotyAdjStep: %d", FactoryAdjustStep ) ;
  if (FactoryAdjustStep == 0) {
    // 1: SID3E_ADU $00 憲怣
    putValue(EnvSID3E_RspNecessity_ADU,0);
    putValue(EnvSID3E_Tx_ADU,1); // 憲怣儃僞儞傪墴偡
    setTimer(msFactoryRespTimer,1); // 1ms屻偵儃僞儞傪棧偡    
    FactoryAdjustStep = 1;
//    return;
  } else if (FactoryAdjustStep == 1) {
    sysSetVariableInt(sysvar::VERI::Factory::S01,1);  // 侾偮傔姰椆丂俀偮栚傊
      // 2: SID10_ADU $01:僨僼僅儖僩
    putValue(EnvSID10_ID_ADU, 1); // $01:僨僼僅儖僩
    putValue(EnvSID10_RspNecessity_ADU, 0); // 傾僋僥傿僽儗僗億儞僗梫
    putValue(EnvSID10_Tx_ADU,1); // 憲怣儃僞儞傪墴偡
    setTimer(msFactoryRespTimer,1); // 1ms屻偵儃僞儞棧偡
    FactoryAdjustStep = 2;
  } else if (FactoryAdjustStep == 2) {
    sysSetVariableInt(sysvar::VERI::Factory::S02,1); //俀偮傔姰椆俁偮傔傊恑傓
      // 3: SID10_ADU $03:奼挘
    putValue(EnvSID10_ID_ADU, 3); //$03:奼挘
    putValue(EnvSID10_RspNecessity_ADU, 0); //傾僋僥傿僽儗僗億儞僗梫
    putValue(EnvSID10_Tx_ADU,1); //丂憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1); // 1ms屻偵儃僞儞棧偡
    FactoryAdjustStep = 3;
  } else if (FactoryAdjustStep == 3) {
    sysSetVariableInt(sysvar::VERI::Factory::S03,1); // 俁偮栚姰椆
      // 4: SID2E_PVM $5140:岝幉挷惍忔堳彂偒崬傒   01
    putValue(EnvSID2E_DID_Tx_PVM,0x5140); // 
    putValue(EnvSID2E_id5140_pos10_Tx_PVM,1) ;
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,10);
    FactoryAdjustStep = 4;
  } else if (FactoryAdjustStep == 4) {
    sysSetVariableInt(sysvar::VERI::Factory::S04,1);
      // 5: SID2E_PVM $5141:岝幉挷惍専嵏敾掕... 丂    // Automation偺庤弴偱偼憲偭偰偄側偄偑丄MICO偺庤弴彂偱偼憲偭偰偄傞
    putValue(EnvSID2E_DID_Tx_PVM,0x5141);
    putValue(EnvSID2E_id5141_pos10_Tx_PVM,0x0);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,10);
    FactoryAdjustStep = 5;
  } else if (FactoryAdjustStep == 5) {
    sysSetVariableInt(sysvar::VERI::Factory::S05,1);
      // 6: SID2E_PVM $5142:帺摦岝幉僞乕僎僢僩儅乕僇乕埵抲(屻曽)_PVM  
    putValue(EnvSID2E_DID_Tx_PVM,0x5142);
    putValue(EnvSID2E_id5142_pos20_Tx_PVM,4850);
    putValue(EnvSID2E_id5142_pos40_Tx_PVM,1400);
    putValue(EnvSID2E_id5142_pos60_Tx_PVM,220);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 6;
  } else if (FactoryAdjustStep == 6) {
    sysSetVariableInt(sysvar::VERI::Factory::S06,1);
      // 7: SID2E_PVM $5143:帺摦岝幉僞乕僎僢僩儅乕僇乕埵抲丂1500丄1400丄220
    putValue(EnvSID2E_DID_Tx_PVM,0x5143);
    putValue(EnvSID2E_id5143_pos20_Tx_PVM,1500);
    putValue(EnvSID2E_id5143_pos40_Tx_PVM,1400);
    putValue(EnvSID2E_id5143_pos60_Tx_PVM,220);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 7;
  } else if (FactoryAdjustStep == 7) {
    sysSetVariableInt(sysvar::VERI::Factory::S07,1);
      // 8: SID2E_PVM $5144:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂0040  僞乕僎僢僩儅乕僇乕H曽岦偺傒"1", 懠偼"0"
    putValue(EnvSID2E_DID_Tx_PVM,0x5144);
    putValue(EnvSID2E_id5144_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5144_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 8;
  } else if (FactoryAdjustStep == 8) {
    sysSetVariableInt(sysvar::VERI::Factory::S08,1);
      // 9: SID2E_PVM $5145:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂5600丄0丄50
    putValue(EnvSID2E_DID_Tx_PVM,0x5145);
    putValue(EnvSID2E_id5145_pos20_Tx_PVM,5600);
    putvalue(EnvSID2E_id5145_pos40_Tx_PVM,0);
    putvalue(EnvSID2E_id5145_pos60_Tx_PVM,50);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 9;
  } else if (FactoryAdjustStep == 9) {
    sysSetVariableInt(sysvar::VERI::Factory::S09,1);
      //10: SID2E_PVM $5146:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂0040丂僞乕僎僢僩儅乕僇乕H曽岦偺傒"1", 懠偼"0"
    putValue(EnvSID2E_DID_Tx_PVM,0x5146);
    putValue(EnvSID2E_id5146_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5146_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 10;
  } else if (FactoryAdjustStep == 10) {
    sysSetVariableInt(sysvar::VERI::Factory::S10,1);
      //11: SID2E_PVM $5147:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂2260丄0丄50
    putvalue(EnvSID2E_DID_Tx_PVM,0x5147);
    putvalue(EnvSID2E_id5147_pos20_Tx_PVM,2260);
    putvalue(EnvSID2E_id5147_pos40_Tx_PVM,0);
    putvalue(EnvSID2E_id5147_pos60_Tx_PVM,50);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 11;    
  } else if (FactoryAdjustStep == 11) {
    sysSetVariableInt(sysvar::VERI::Factory::S11,1);
      //12: SID2E_PVM $5148:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂0040  僞乕僎僢僩儅乕僇乕H曽岦偺傒"1!, 懠偼"0"
    putvalue(EnvSID2E_DID_Tx_PVM,0x5148);
    putValue(EnvSID2E_id5148_pos17_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos16_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos15_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos14_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos13_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos12_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos11_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos10_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos27_Tx_PVM,0);
    putValue(EnvSID2E_id5148_pos26_Tx_PVM,64);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 12;
  } else if (FactoryAdjustStep == 12) {
    sysSetVariableInt(sysvar::VERI::Factory::S12,1);
    //13: SID2E_PVM $5149:帺摦岝幉僞乕僎僢僩儅乕僇乕丂丂丂0,1450,700
    putValue(EnvSID2E_DID_Tx_PVM,0x5149);
    putvalue(EnvSID2E_id5149_pos20_Tx_PVM,0);
    putvalue(EnvSID2E_id5149_pos40_Tx_PVM,1450);
    putvalue(EnvSID2E_id5149_pos60_Tx_PVM,700);
    putValue(EnvSID2E_Tx_PVM,1);  // 憲怣儃僞儞墴偡
    setTimer(msFactoryRespTimer,1);
    FactoryAdjustStep = 13;
  } else if (FactoryAdjustStep == 13) {
    sysSetVariableInt(sysvar::VERI::Factory::S13,1);
    //14: SID10_ADU $01:僨僼僅儖僩
    putValue(EnvSID10_ID_ADU, 1); // $01:僨僼僅儖僩
    putValue(EnvSID10_RspNecessity_ADU, 0); // 傾僋僥傿僽儗僗億儞僗梫
    putValue(EnvSID10_Tx_ADU,1); // 憲怣儃僞儞傪墴偡
    setTimer(msFactoryRespTimer,1); // 1ms屻偵儃僞儞棧偡
    FactoryAdjustStep = 15;    // Step14傪旘偽偡
  } else if (FactoryAdjustStep == 14) {
    sysSetVariableInt(sysvar::VERI::Factory::S14,1);
    //15: SID3E_ADU $00 憲怣掆巭
    // 偙偺僐儅儞僪偼墳摎偑婣偭偰偙側偄傛偆偵尒偊傞丅250805 巙搚抧偝傫偵妋擣偟偨偲偙傠晄梫偱偼側偄偐偲偺偙偲偱嶍彍
//    putValue(EnvSID3E_Resp_Flag_ADU,0);
//    putValue(EnvSID3E_RspNecessity_ADU,0);
//    putValue(EnvSID3E_Stop_ADU,1); // 憲怣儃僞儞傪墴偡
//    setTimer(msFactoryRespTimer,1); // 1ms屻偵儃僞儞傪棧偡        
//    FactoryAdjustStep = 15;
  } else if (FactoryAdjustStep == 15) {
    sysSetVariableInt(sysvar::VERI::Factory::S15,1);
    setTimer(msExecInterval,CommandInterval);
    alive_msExecInterval = 1;
  } else {
    write("偙偙偵偼棃側偄丂at factoryadjust()");
  }
}
  
/*****************************************************************************************
// 僟僀傾僌 1483憲怣
//--------------------------------------------------------------------------------
// 娭悢 outputExtMsg1483()  
//    堷悢側偟
//    栠傝抣側偟
//  摦嶌丗僟僀傾僌 1483憲怣
//    庴怣偺5僶僀僩栚偑丄價儏乕僨乕僞惗惉偺忬懺傪昞偡 0x05偵側偭偨傜姰椆
//    奼挘ID丗0x18DA75E0
//    DLC : 8僶僀僩
//    憲怣僨乕僞丗0x03, 0x22, 0x14, 0x83, 0x00, 0x00, 0x00, 0x00(屻傠偺係偮偼堄枴側偟乯
//    庴怣僨乕僞丗0x04, 0x62, 0x14, 0x83, 0xXX, 0x00, 0x00, 0x00(屻傠偺俁偮偼堄枴側偟乯
//        data(5)偺0xXX偑價儏乕僨乕僞惗惉偺忬懺
//    懳徾曄悢丗丂signal DSBus::CGW_D::AVN1S73::SW_PVM
//    摦嶌 僟僀傾僌1483傪憲怣偡傞
//    忦審 偄偮偱傕憲怣壜擻
******************************************************************************************/
void outputExtMsg1483() {
  ExtMsg1483.id = mkExtID(0x18DA75E0);
  ExtMsg1483.dlc=8;
  ExtMsg1483.byte(0) = 0x03;
  ExtMsg1483.byte(1) = 0x22;
  ExtMsg1483.byte(2) = 0x14;
  ExtMsg1483.byte(3) = 0x83;
  output(ExtMsg1483);
}

/*****************************************************************************************
// 僟僀傾僌 1483憲怣
// VERI 僷僱儖偐傜丄Msg1483儃僞儞傪墴偟偨帪偺摦嶌
******************************************************************************************/
on sysvar sysvar::VERI::Msg1483 {
  if (sysGetVariableInt(sysvar::VERI::Msg1483) == 0) {
    return;
  } else {
    outputExtMsg1483();
    write("Send 1483"); 
    sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 0);  //昞帵徚偟
    sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 0); // 昞帵徚偟
  }
}

/*****************************************************************************************
// 僟僀傾僌1483偺儗僗億儞僗偺庴怣 (僗僋儕僾僩偐傜偺1483偲丄僷僱儖偐傜偺1483偺椉曽偵懳墳
// 奼挘ID偺偨傔偐丄DID偺傒慖戰偟偰庴怣偡傞偙偲偑偱偒側偄偨傔丄慡晹庴怣偟偰ID傪斾妑偟偰庴怣偡傞偙偲偵偟偨
******************************************************************************************/
on message * {
//  write("%X", this.id);
  if (this.id == mkExtId(0x18DAE075)) {
    // msg 1483張棟乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕
    if ((this.byte(2)==0x14) && (this.byte(3)==0x83)) { 
//    write("Receive 1483 %02X %02X %02X %02X %02X %02X %02X %02X",this.byte(0),this.byte(1),this.byte(2),this.byte(3),this.byte(4),this.byte(5),this.byte(6),this.byte(7));
    write("Receive 1483 %02X",this.byte(4));
      if (this.byte(4) == 5) {
        sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 1);
        sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 0);
      } else {
        sysSetVariableInt(sysvar::VERI::Msg1483_ret_other5, 1);
        sysSetVariableInt(sysvar::VERI::Msg1483_ret5, 0);
      }
      
      sysSetVariableInt(sysvar::VERI::Msg1483_retval, this.byte(4));
    
    
      if (isMsg1483FromScript == 1) {// 僗僋儕僾僩偐傜偺屇傃弌偟
        if (this.byte(4) == 5) {  //栠傝抣偑俆偺応崌丄捠忢偺幚峴偵栠傞
          cancelTimer(msMsg1483Retry); //儕僩儔僀僞僀儅乕偺僉儍儞僙儖    
                                     //僗僋儕僾僩幚峴嵞奐
          setTimer(msExecInterval,CommandInterval);
          alive_msExecInterval = 1;
                                    //屇傃弌偟尦傪帵偡曄悢傪栠偡乮偙傟傪偟側偄偲丄僷僱儖偐傜偺屇傃弌偟偱儕僩儔僀偟偰偟傑偆乯
          isMsg1483FromScript = 0;
        } else {                  //栠傝抣偑俆埲奜偺応崌儕僩儔僀偡傞
        //儕僩儔僀僞僀儅乕偺僙僢僩
          setTimer(msMsg1483Retry, 500) ;
        } 
      }else { // 僗僋儕僾僩偐傜偱偼側偄屇傃弌偟乮僷僱儖儃僞儞乯
        }
      }
    // msg DID張棟乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕乕    
    // 僷僱儖屇傃弌偟偵傛傞DID庢摼
    //-------13A0---------
//    write("this.byte(2)%02X,this.byte(3)%02X",this.byte(2),this.byte(3));
    if ((waitA0 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA0)) {
      ret_BackNum = this.byte(4);
      write("LastBackView: %02X",ret_BackNum);
      sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,ret_BackNum);
      updateLastBackViewText(ret_BackNum);
      waitA0 = 0;
    }
    //-------13A1---------
    if ((waitA1 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA1)) {
      ret_FrontNum = this.byte(4);
      write("LastFrontView: %02X",ret_FrontNum);
      sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,ret_FrontNum);
      updateLastFrontViewText(ret_FrontNum);
      waitA1 = 0;
    }
    //-------13A3---------
    if ((waitA3 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA3)) {
      ret_AutoDisp = this.byte(4);
      write("LastAutoDisp: %02X",ret_AutoDisp);
      sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,ret_AutoDisp);
      updateAutoDispMode(ret_AutoDisp);
      waitA3 = 0;
    }
    //-------13A4------------
    if ((waitA4 = 1)&&(this.byte(2)==0x13)&&(this.byte(3)==0xA4)) {
      ret_AutoCamera = this.byte(4);
      write("LastAutoCamera: %02X",ret_AutoCamera);
      sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,ret_AutoCamera);
      updateCameraViewAutoOff(ret_AutoCamera);
      waitA4 = 0;
    }
    
    //僐儅儞僪偐傜偺屇傃弌偟偵傛傞DID庢摼
    if(initViewActive == 1)
    {
      //-------13A0------------
    if ((this.byte(2)==0x13)&&(this.byte(3)==0xA0)) {
        ret_BackNum = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,ret_BackNum);
        updateLastBackViewText(ret_BackNum);
        didlow = 0xA1;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A0");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA1)) {
      //-------13A1-------------
        ret_FrontNum = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::LastFrontViewNum,ret_FrontNum);
        updateLastFrontViewText(ret_FrontNum);
        didlow = 0xA3;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A1");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA3)) {
      //--------13A3-------------
        ret_AutoDisp = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::AutoDispModeNum,ret_AutoDisp);
        updateAutoDispMode(ret_AutoDisp);
        didlow = 0xA4;
        setTimer(sendDID,100);
        write("INIT_VIEW : send DID 13A3");
        return;
      } else if ((this.byte(2)==0x13)&&(this.byte(3)==0xA4)) {
      //--------13A4--------------
        ret_AutoCamera = this.byte(4);
        sysSetVariableInt(sysvar::VERI::DID::CameraViewAutoOffNum,ret_AutoCamera);
        updateCameraViewAutoOff(ret_AutoCamera);
        sysSetVariableInt(sysvar::VERI::DID::didReceived,1);
        write("INIT_VIEW : send DID 13A4");
        return;
      }
    }
  }
}

/*****************************************************************************************
//DID庢摼梡偺僞僀儅乕
*****************************************************************************************/
on timer sendDID{
  write("DID憲怣");
  if ((didlow == 0xA0) || (didlow == 0xA1) || (didlow == 0xA3) || (didlow == 0xA4)){
    outputDiagReq(didlow);
  }
  cancelTimer(sendDID);
}

/*****************************************************************************************
 僟僀傾僌1483偺儕僩儔僀僞僀儅乕丂
--------------------------------------------------------------------------------
 僞僀儅乕僀儀儞僩僴儞僪儔 msMsg1483Retry   
    摦嶌丗僞僀儉傾僢僾偵偰丄僟僀傾僌1483傪嵞憲偡傞
******************************************************************************************/
on timer msMsg1483Retry {  // 1483偺儕僩儔僀僞僀儅乕
  cancelTimer(msMsg1483Retry);
  outputExtMsg1483();
}

