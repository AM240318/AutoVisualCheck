/*****************************************************************************************
僐儞儃儃僢僋僗偺僥僗僩梡
******************************************************************************************/
on sysvar sysvar::VERI::GetC { //僐儞儃儃僢僋僗僥僗僩梡
  if (sysGetVariableInt(sysvar::VERI::GetC) == 0) {
    return;
  }
//  write("0x%04X",getValue(SigDt_BDB1S08_STRG_WHL));
  
}

/*****************************************************************************************
僉乕僀儀儞僩僴儞僪儔 msMsg1483Retry   
    摦嶌丗僉乕儃乕僪偱A傪墴偟偨傜丄Folder Read and Run儃僞儞傪摦嶌偝偣傞
******************************************************************************************/
on key 'a'{ // Folder and Run shortcut
  
  sysSetVariableInt(sysvar::VERI::sysReadFolder, 1);
  
  //write("aaa"); 
  
}

/***************************************************************************************
//DID13A0庢摼
//--------------------------------------------------------------------------------
// 娭悢 outputDiagReq()
//didlow:
//  0xA0 仺 13A0(LastBackView)
//  0xA1 仺 13A1(LastFrontView)
//  0xA3 仺 13A3(AutoDispMode)
//  0xA4 仺 13A4(CameraViewAutoOff)
******************************************************************************************/
void outputDiagReq(byte didlow)
{
  DiagReq.id = mkExtId(DIAG_REQ_ID);
  DiagReq.dlc=8;
  
  DiagReq.byte(0) = 0x03;
  DiagReq.byte(1) = 0x22;
  DiagReq.byte(2) = 0x13;
  DiagReq.byte(3) = didlow;
  DiagReq.byte(4) = 0x00;
  DiagReq.byte(5) = 0x00;
  DiagReq.byte(6) = 0x00;
  DiagReq.byte(7) = 0x00;
  output(DiagReq);
}


/*****************************************************************************************
LastBackView3忬懺昞帵
-1丗枹庢摼
0丗僫儘乕僶僢僋價儏乕
1丗儚僀僪僶僢僋價儏乕
*****************************************************************************************/
void updateLastBackViewText(int v){
  if(v == 0) {
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"僫儘乕僶僢僋價儏乕");
  } else if(v == 1){
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"儚僀僪僶僢僋價儏乕");
  } else {
    sysSetVariableString(sysvar::VERI::DID::LastBackViewText,"枹庢摼");
  }
}



/**************************************************************************************
僷僱儖儃僞儞丗getLastBackView
**************************************************************************************/
on sysvar sysvar::VERI::DID::getLastBackView{
  if (sysGetVariableInt(sysvar::VERI::DID::getLastBackView) == 0) {
    return;
    
  } else if (initViewActive == 1){
    write("INIT_VIEW running");
    return;
    
  } else {
    
    sysSetVariableInt(sysvar::VERI::DID::LastBackViewNum,-1);
    updateLastBackViewText(-1);
    
    waitA0 = 1;
    outputDiagReq(0xA0);
    write("send DID13A0");
    
  }
}


